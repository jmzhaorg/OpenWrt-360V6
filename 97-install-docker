#!/bin/sh
# 97-install-docker
# 首次启动时安装 dockerd 并设置开机自启
# 依赖 98-fix-apk-feeds 先执行（数字小的先跑，97 < 98，
# 但 uci-defaults 按文件名字母顺序执行，97 < 98 确保顺序正确）

LOG_TAG="install-docker"

# 检查 dockerd 是否已安装
if command -v dockerd >/dev/null 2>&1; then
    echo "✅ dockerd 已安装，跳过"
    # 确保服务已启用
    service dockerd enable 2>/dev/null
    service dockerd start  2>/dev/null
    exit 0
fi

echo "⏳ dockerd 未安装，开始安装..." | logger -t "$LOG_TAG"

# 等待 apk update 完成（98-fix-apk-feeds 应已执行）
sleep 3

# 安装 docker 相关包
apk add --no-cache \
    dockerd \
    docker \
    docker-compose \
    luci-app-dockerman \
    luci-i18n-dockerman-zh-cn \
    kmod-nf-conntrack \
    kmod-nf-conntrack6 \
    kmod-br-netfilter \
    kmod-veth \
    cgroupfs-mount \
    2>&1 | logger -t "$LOG_TAG"

# 挂载 cgroup（Docker 必须）
if ! mount | grep -q cgroup2; then
    mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
fi

# 启用并启动 dockerd
service dockerd enable 2>&1 | logger -t "$LOG_TAG"
service dockerd start  2>&1 | logger -t "$LOG_TAG"

# 等待启动
sleep 5

# 验证
if service dockerd status 2>/dev/null | grep -q running; then
    echo "✅ dockerd 启动成功" | logger -t "$LOG_TAG"
else
    echo "⚠️  dockerd 启动失败，请手动执行: service dockerd start" | logger -t "$LOG_TAG"
fi

exit 0
