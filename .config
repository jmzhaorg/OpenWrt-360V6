# ========== 目标设备 ==========
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y
# 360V6: 128MB NAND，UBI 自动管理分区，不使用 PARTSIZE
# CONFIG_TARGET_ROOTFS_PARTSIZE is not set
CONFIG_TARGET_ROOTFS_SQUASHFS=y
# NAND 同时需要 UBI rootfs（sysupgrade 使用 squashfs-in-ubi）
CONFIG_TARGET_ROOTFS_UBIFS=y

# ========== 编译优化 ==========
CONFIG_CCACHE=y
CONFIG_SSTRIP=y

# ========== 基础网络守护进程（必须显式声明，防止 defconfig 裁剪）==========
# FIX-B3: netifd 是获取 IP 的核心守护进程，必须显式声明防止被优化掉
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_ubusd=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_procd-ujail=y

# ========== 无线合规与诊断 ==========
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_mtr=y
CONFIG_PACKAGE_tcpdump-mini=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y

# ========== LuCI 基础 ==========
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
# CONFIG_PACKAGE_luci-lib-ipkg is not set
CONFIG_PACKAGE_luci-ssl=y
# px5g-wolfssl 与 px5g-mbedtls 冲突，禁用 wolfssl
# CONFIG_PACKAGE_px5g-wolfssl is not set
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# ========== 中文界面 ==========
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ========== 网络基础组件 ==========
# FIX-R2: dnsmasq-full 只做 DHCP，不监听 53
#          smartdns 监听 5335，由 99-custom-ip 配置 dnsmasq 转发
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-nat6=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_libustream-openssl=y
CONFIG_PACKAGE_libopenssl=y

# ========== 无线驱动 ==========
# FIX-B1: 360V6 = IPQ6000，板载无线固件包为 ath11k-firmware-ipq60xx
#          ath11k-firmware-qcn9074 是 PCIe 外接卡固件，与板载无线无关
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_ath11k-firmware-ipq60xx=y
# CONFIG_PACKAGE_ath11k-firmware-qcn9074 is not set
# CONFIG_PACKAGE_kmod-ath10k-ct is not set

# ========== USB 支持 ==========
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y
CONFIG_PACKAGE_smartmontools=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_fdisk=y

# ========== HomeProxy（LuCI 内置，sing-box 运行时安装）==========
# FIX: sing-box ~30MB，不编入固件，由 96-install-extras 首次启动时 apk 安装
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
# CONFIG_PACKAGE_sing-box is not set
# CONFIG_PACKAGE_sing-box-tiny is not set
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_ucode-mod-digest=y
# CONFIG_PACKAGE_sing-box-geosite is not set
# CONFIG_PACKAGE_sing-box-geoip is not set

# ========== 终端与工具 ==========
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_file=y

# ========== 应用插件 ==========
CONFIG_PACKAGE_luci-lua-runtime=y
# luci-app-fileassistant 运行时安装
# CONFIG_PACKAGE_luci-app-fileassistant is not set
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_etherwake=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y
CONFIG_PACKAGE_luci-app-crontabs=y
CONFIG_PACKAGE_luci-i18n-crontabs-zh-cn=y

# ========== CPU 频率调节 ==========
CONFIG_PACKAGE_luci-app-cpufreq=y
# CONFIG_PACKAGE_luci-i18n-cpufreq-zh-cn is not set

# ========== Docker 内核模块（必须内置，apk 无法安装 kmod）==========
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_docker-compose is not set
# CONFIG_PACKAGE_cgroupfs-mount is not set
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-dummy=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-conntrack6=y
CONFIG_PACKAGE_kmod-nf-nat=y
# CONFIG_PACKAGE_kmod-ipt-extra is not set
# CONFIG_PACKAGE_kmod-ipt-conntrack is not set
# CONFIG_PACKAGE_docker is not set

# ========== Lucky（运行时安装）==========
# CONFIG_PACKAGE_lucky is not set
# CONFIG_PACKAGE_luci-app-lucky is not set
CONFIG_PACKAGE_libpthread=y

# ========== 硬件加速 ==========
# FIX-BOOT3: kmod-fast-classifier 与 firewall4/nftables 在 IPQ60xx 上有 hook 冲突
# 表现：LAN 设备获取不到 IP，流量被静默丢弃
# 彻底移除 SFE，改用 nftables 内置 flowtable（firewall4 自动启用）
# 如需 SFE 可刷入后: apk add kmod-sfe kmod-fast-classifier 并验证稳定性
# CONFIG_PACKAGE_kmod-sfe is not set
# CONFIG_PACKAGE_kmod-fast-classifier is not set
# BBR 拥塞控制（TCP 层，不影响转发 hook，安全保留）
CONFIG_PACKAGE_kmod-tcp-bbr=y
# NSS 硬件加速：master 分支不稳定，按需运行时安装
# CONFIG_PACKAGE_kmod-qca-nss-drv is not set
# CONFIG_PACKAGE_kmod-qca-nss-gmac is not set
# CONFIG_PACKAGE_luci-app-nss-pbuf is not set

# ========== AdGuard Home（LuCI 内置，二进制运行时安装）==========
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y
# CONFIG_PACKAGE_adguardhome is not set

# ========== SmartDNS ==========
# FIX-R2: smartdns 配置为监听 5335，dnsmasq-full 转发到 5335
# 绝不让两者同时监听 53
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_smartdns=y

# ========== DDNS 动态域名 ==========
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y

# ========== UPnP ==========
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_miniupnpd-nftables=y

# ========== 流量监控 ==========
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-zh-cn=y

# ========== Samba 文件共享（LuCI 内置，samba4-server 运行时安装）==========
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y
# samba4-server ~15MB，运行时安装
# CONFIG_PACKAGE_samba4-server is not set

# ========== IPv6 支持 ==========
CONFIG_PACKAGE_luci-app-ipv6helper=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
# kmod-nft-nat6 已在上方网络组件定义，不重复
# FIX: 移除 kmod-ip6tables，与 nftables 体系冲突
# CONFIG_PACKAGE_kmod-ip6tables is not set

# ========== 硬件随机数 ==========
CONFIG_PACKAGE_kmod-qca-rng=y

# ========== 明确禁用 ==========
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-mosdns is not set
# CONFIG_PACKAGE_v2ray-geoip is not set
# CONFIG_PACKAGE_v2ray-geosite is not set
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_hysteria is not set
# CONFIG_PACKAGE_naiveproxy is not set
# CONFIG_PACKAGE_tuic-client is not set
