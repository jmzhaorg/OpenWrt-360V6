cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

# 颜色（终端支持时）
if [ -t 1 ]; then
    _G="\033[32m"; _R="\033[31m"; _Y="\033[33m"; _B="\033[36m"; _N="\033[0m"
else
    _G=""; _R=""; _Y=""; _B=""; _N=""
fi

_ok()   { printf "${_G}[OK]${_N}  %s\n" "$1"; }
_warn() { printf "${_Y}[..]${_N}  %s\n" "$1"; }
_info() { printf "     ${_B}%s${_N}\n" "$1"; }

echo "=== 360 V6 状态 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo "版本  : V3.8"
echo ""

# ── 基础环境 ─────────────────────────────────
if [ -f /etc/install-extras-done ]; then
    _ok "基础环境：已完成"
else
    _warn "基础环境：待触发"
fi

# ── 重型应用 ──────────────────────────────────
if [ -f /etc/install-usb-done ]; then
    _ok "重型应用：已完成"

    # Docker
    if [ -f "$_SD/docker-done" ]; then
        if docker info >/dev/null 2>&1; then
            _crun=$(docker ps -q 2>/dev/null | wc -l | tr -d ' ')
            _call=$(docker ps -aq 2>/dev/null | wc -l | tr -d ' ')
            _info "Docker : 运行中（容器 运行:${_crun} / 总计:${_call}）"
        else
            _info "Docker : 已安装但未运行"
        fi
    else
        _info "Docker : 未完成"
    fi

    # AGH
    if [ -f "$_SD/agh-done" ]; then
        _agh_port=""
        for _p in 53 5353; do
            if netstat -lnup 2>/dev/null | grep -q ":${_p} .*AdGuard\|:${_p} .*AdGuardHome"; then
                _agh_port="$_p"; break
            fi
        done
        # 也尝试用 nc 探测
        [ -z "$_agh_port" ] && nc -z 127.0.0.1 53 2>/dev/null && _agh_port="53"

        if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
            _info "AGH    : 运行中（DNS :${_agh_port:-?}，管理 :3000）"

            # AGH 统计（读配置文件中的 work_dir，调用本地 API）
            _mp=$(_get_usb_mount)
            _agh_work="${_mp}/AdGuardHome"
            _agh_yaml="${_agh_work}/AdGuardHome.yaml"
            if [ -f "$_agh_yaml" ] && command -v curl >/dev/null 2>&1; then
                # 尝试从 yaml 读管理端口
                _web_port=$(grep -m1 "^  port:" "$_agh_yaml" 2>/dev/null | awk '{print $2}')
                [ -z "$_web_port" ] && _web_port=3000
                _stats=$(curl -s --max-time 2 \
                    "http://127.0.0.1:${_web_port}/control/stats" 2>/dev/null)
                if [ -n "$_stats" ]; then
                    _total=$(echo "$_stats" | grep -o '"num_dns_queries":[0-9]*' | cut -d: -f2)
                    _blocked=$(echo "$_stats" | grep -o '"num_blocked_filtering":[0-9]*' | cut -d: -f2)
                    _blocked_pct=0
                    [ "${_total:-0}" -gt 0 ] && \
                        _blocked_pct=$(( _blocked * 100 / _total ))
                    _info "AGH 统计: 查询 ${_total:-0} / 拦截 ${_blocked:-0} (${_blocked_pct}%)"
                fi

                # 上游 DNS
                _upstream=$(grep -A2 "^upstream_dns:" "$_agh_yaml" 2>/dev/null | \
                    grep "^ *-" | head -3 | sed 's/^ *- //' | tr '\n' ' ')
                [ -n "$_upstream" ] && _info "上游DNS : ${_upstream}"
            fi
        else
            _info "AGH    : 未运行"
        fi
    elif pgrep -f "AdGuardHome" >/dev/null 2>&1; then
        _info "AGH    : 运行中（等待 agh-finalize）"
    else
        _info "AGH    : 未完成"
    fi
else
    _warn "重型应用：待 U 盘"
fi

echo ""

# ── 系统资源 ──────────────────────────────────
df -h /overlay 2>/dev/null | awk 'NR==2{printf "Flash : %s / %s (%s)\n",$3,$2,$5}'
free 2>/dev/null | awk '/Mem:/{printf "内存  : %dMB 已用 / %dMB 总计\n",$3/1024,$2/1024}'

# Swap
_swaptotal=$(grep SwapTotal /proc/meminfo 2>/dev/null | awk '{print $2}')
_swapfree=$(grep SwapFree  /proc/meminfo 2>/dev/null | awk '{print $2}')
if [ "${_swaptotal:-0}" -gt 0 ]; then
    _swapused=$(( (_swaptotal - _swapfree) / 1024 ))
    _swaptotalm=$(( _swaptotal / 1024 ))
    printf "Swap  : %dMB 已用 / %dMB 总计\n" "$_swapused" "$_swaptotalm"
fi

# 负载
_load=$(cat /proc/loadavg 2>/dev/null | cut -d' ' -f1-3)
[ -n "$_load" ] && echo "负载  : $_load"

# 开机时间
_uptime_s=$(awk '{printf "%d", $1}' /proc/uptime 2>/dev/null)
if [ -n "$_uptime_s" ]; then
    _uph=$(( _uptime_s / 3600 ))
    _upm=$(( (_uptime_s % 3600) / 60 ))
    printf "运行  : %d 时 %d 分\n" "$_uph" "$_upm"
fi

echo ""

# ── USB ───────────────────────────────────────
_USB=$(_get_usb_mount)
if [ -n "$_USB" ]; then
    _usbfree=$(df -h "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
    echo "USB   : $_USB (已挂载，剩余 ${_usbfree:-?})"
else
    echo "USB   : 未检测到"
fi

# CPU 温度
__temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
if [ -n "$__temp" ]; then
    __tc=$((__temp / 1000))
    if [ "$__temp" -gt 75000 ]; then
        printf "${_R}CPU温度: %d°C（过高！）${_N}\n" "$__tc"
    elif [ "$__temp" -gt 65000 ]; then
        printf "${_Y}CPU温度: %d°C（偏高）${_N}\n" "$__tc"
    else
        printf "CPU温度: %d°C\n" "$__tc"
    fi
fi

echo ""
echo "管理  : http://192.168.2.1:3000"
echo "命令  : 360v6-health [--fix] | 360v6-tune --mode=performance|balanced|powersave"
echo "卸载  : 360v6-uninstall"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ══════════════════════════════════════════════════════════════
# 模块 0b：360v6-health（不变，沿用 V3.7）
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-health << 'HEALTHEOF'
#!/bin/sh
_SD="/etc/install-state"
_fix=0
[ "$1" = "--fix" ] && _fix=1

_ok()   { echo "[OK]  $1"; }
_warn() { echo "[WARN] $1"; }
_err()  { echo "[ERR]  $1"; }

_fix_cpu_powersave() {
    for _g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        [ -f "$_g" ] && echo powersave > "$_g" 2>/dev/null
    done
}
_fix_clean_cache()    { rm -rf /tmp/opkg-lists /var/cache/apk 2>/dev/null; }
_fix_start_dockerd()  { /etc/init.d/dockerd start; }
_fix_start_agh()      { /etc/init.d/adguardhome start; }
_fix_disable_dnsmasq() {
    uci set dhcp.@dnsmasq[0].port='0'
    uci commit dhcp
    /etc/init.d/dnsmasq reload
}

_fix_action() {
    [ "$_fix" -eq 1 ] || { echo "[HINT] 修复: $1"; return; }
    echo "[FIX]  $1"
    "$2"
}

echo "=== 360 V6 健康检查 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo ""

_errs=0

__temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
if [ -n "$__temp" ]; then
    __temp_c=$((__temp / 1000))
    if [ "$__temp" -gt 75000 ]; then
        _err "CPU 温度过高 (${__temp_c}°C) > 75°C"
        _fix_action "切换 CPU 为 powersave" _fix_cpu_powersave
        _errs=$((_errs + 1))
    else
        _ok "CPU 温度: ${__temp_c}°C"
    fi
fi

_flash_pct=$(df /overlay 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5); print $5}')
if [ -z "$_flash_pct" ]; then
    _warn "无法读取 Flash 使用率"
elif [ "$_flash_pct" -ge 90 ]; then
    _err "Flash 使用率 ${_flash_pct}%"
    _fix_action "清理缓存" _fix_clean_cache
    _errs=$((_errs + 1))
else
    _ok "Flash 使用率 ${_flash_pct}%"
fi

grep -q swapfile /proc/swaps 2>/dev/null && _ok "Swap 已激活" || _warn "Swap 未激活"

if [ -f "$_SD/docker-done" ]; then
    if docker info >/dev/null 2>&1; then
        _ok "Docker 运行中"
    else
        _err "Docker 未运行"
        _fix_action "启动 dockerd" _fix_start_dockerd
        _errs=$((_errs + 1))
    fi
fi

if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
    _ok "AdGuardHome 运行中"
else
    if [ -f "$_SD/agh-done" ] || [ -f /etc/install-usb-done ]; then
        _err "AdGuardHome 未运行"
        _fix_action "启动 AGH" _fix_start_agh
        _errs=$((_errs + 1))
    fi
fi

if [ -f "$_SD/agh-done" ]; then
    _dnsmasq_on_53=$(netstat -lnup 2>/dev/null | \
        awk '$4 ~ /:53$/ && $NF ~ /dnsmasq/{print 1; exit}')
    if [ "${_dnsmasq_on_53}" = "1" ]; then
        _err "DNS 冲突：dnsmasq 仍监听 53 端口"
        _fix_action "禁用 dnsmasq DNS" _fix_disable_dnsmasq
        _errs=$((_errs + 1))
    else
        _ok "DNS 分配正常"
    fi
fi

echo ""
[ "$_errs" -eq 0 ] && echo "健康检查完成，无异常" || echo "发现 ${_errs} 个问题"
HEALTHEOF
chmod +x /usr/bin/360v6-health

