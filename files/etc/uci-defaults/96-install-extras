#!/bin/sh
# 96-install-extras
# hotplug iface 触发：WAN UP 后自动安装软件包

DONE_FLAG="/etc/install-extras-done"
[ -f "$DONE_FLAG" ] && exit 0

mkdir -p /usr/lib/install-extras

cat > /usr/lib/install-extras/run.sh << 'RUNEOF'
#!/bin/sh
LOG_TAG="install-extras"
DONE_FLAG="/etc/install-extras-done"
LOCK="/tmp/install-extras.lock"

log() { echo "[$(date '+%H:%M:%S')] $1" | logger -t "$LOG_TAG"; }

[ -f "$DONE_FLAG" ] && exit 0
[ -f "$LOCK" ] && exit 0
touch "$LOCK"

log "▶ install-extras 开始"

# ── 清理 video feed ──────────────────────────────────────────────────
for f in /etc/apk/repositories.d/*.list; do
    [ -f "$f" ] && sed -i '/\/video\//d' "$f"
done

# ── 等待网络 + DNS 双重就绪 ──────────────────────────────────────────
sleep 5
NETWORK_OK=0
for i in $(seq 1 60); do
    ping -c 1 -W 2 223.5.5.5 >/dev/null 2>&1 && { NETWORK_OK=1; break; }
    ping -c 1 -W 2 8.8.8.8  >/dev/null 2>&1 && { NETWORK_OK=1; break; }
    sleep 3
done
if [ "$NETWORK_OK" -eq 0 ]; then
    log "❌ 网络不可达，等下次 WAN UP 重试"
    rm -f "$LOCK"; exit 1
fi
log "✅ 网络就绪"

# ── 确保 DNS 可用（smartdns 可能还未就绪）────────────────────────────
DNS_OK=0
for i in $(seq 1 20); do
    nslookup downloads.immortalwrt.org 127.0.0.1 >/dev/null 2>&1 && { DNS_OK=1; break; }
    nslookup downloads.immortalwrt.org 223.5.5.5 >/dev/null 2>&1 && { DNS_OK=1; break; }
    sleep 3
done

if [ "$DNS_OK" -eq 0 ]; then
    log "⚠️  本地 DNS 不可用，临时注入 223.5.5.5"
    # 临时追加，不破坏原有 resolv.conf 软链
    echo "nameserver 223.5.5.5" > /tmp/resolv-extras.conf
    export RESOLV_CONF=/tmp/resolv-extras.conf
    # OpenWrt wget/apk 读取 /etc/resolv.conf，直接写入临时 nameserver
    # 注意：这里写的是真实文件，不是软链目标
    ORIG_RESOLV=$(cat /etc/resolv.conf 2>/dev/null)
    echo "nameserver 223.5.5.5" >> /etc/resolv.conf
    DNS_INJECTED=1
fi

# ── 修复 apk TLS 并验证 apk update ──────────────────────────────────
fix_apk_and_update() {
    # 先尝试 HTTPS
    if apk update 2>&1 | tee /tmp/apk-update.log | logger -t "$LOG_TAG"; then
        if ! grep -q "unavailable" /tmp/apk-update.log; then
            log "✅ apk update (HTTPS) 成功"
            return 0
        fi
    fi

    log "⚠️  HTTPS apk update 失败，切换到 HTTP..."
    for f in /etc/apk/repositories.d/*.list; do
        [ -f "$f" ] && sed -i \
            's|https://downloads.immortalwrt.org|http://downloads.immortalwrt.org|g' "$f"
    done

    if apk update 2>&1 | tee /tmp/apk-update.log | logger -t "$LOG_TAG"; then
        if ! grep -q "unavailable" /tmp/apk-update.log; then
            log "✅ apk update (HTTP) 成功"
            # 同步切换 apk TLS 后端到 openssl（HTTP 下可以正常安装）
            WORLD="/etc/apk/world"
            if grep -q "^apk-mbedtls$" "$WORLD" 2>/dev/null; then
                sed -i 's/^apk-mbedtls$/apk-openssl/' "$WORLD"
                apk fix 2>&1 | logger -t "$LOG_TAG" || true
            fi
            return 0
        fi
    fi

    log "❌ apk update 彻底失败"
    return 1
}

if ! fix_apk_and_update; then
    log "❌ 无法更新包索引，等下次重试"
    [ -n "$DNS_INJECTED" ] && /etc/init.d/dnsmasq restart 2>/dev/null || true
    rm -f "$LOCK"; exit 1
fi

# ── 安装函数：失败时记录但继续，最终统计 ────────────────────────────
INSTALL_FAIL=0
install_pkg() {
    log "📦 安装: $*"
    if apk add --no-cache "$@" 2>&1 | logger -t "$LOG_TAG"; then
        log "✅ 完成: $*"
    else
        log "⚠️  失败: $*（可手动: apk add $*）"
        INSTALL_FAIL=$((INSTALL_FAIL + 1))
    fi
}

install_pkg adguardhome luci-app-adguardhome luci-i18n-adguardhome-zh-cn
install_pkg samba4-server luci-app-samba4 luci-i18n-samba4-zh-cn
install_pkg dockerd docker docker-compose cgroupfs-mount
install_pkg luci-app-dockerman luci-i18n-dockerman-zh-cn
install_pkg lucky luci-app-lucky luci-i18n-lucky-zh-cn
install_pkg luci-app-fileassistant
install_pkg luci-app-crontabs luci-i18n-crontabs-zh-cn
install_pkg smartmontools lsblk fdisk bash htop

# ── 配置并启动 Docker ────────────────────────────────────────────────
if command -v dockerd >/dev/null 2>&1; then
    mkdir -p /etc/docker
    USB_MOUNT=""
    for mp in /mnt/sda1 /mnt/sda /mnt/usb /mnt/mmcblk0p1; do
        mountpoint -q "$mp" 2>/dev/null && { USB_MOUNT="$mp"; break; }
    done
    if [ -n "$USB_MOUNT" ]; then
        mkdir -p "$USB_MOUNT/docker-data"
        printf '{\n  "data-root": "%s/docker-data",\n  "log-driver": "json-file",\n  "log-opts": {"max-size": "10m", "max-file": "3"}\n}\n' \
            "$USB_MOUNT" > /etc/docker/daemon.json
    else
        printf '{\n  "log-driver": "json-file",\n  "log-opts": {"max-size": "5m", "max-file": "2"}\n}\n' \
            > /etc/docker/daemon.json
    fi
    mountpoint -q /sys/fs/cgroup || mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
    /etc/init.d/dockerd enable 2>/dev/null || true
    /etc/init.d/dockerd start  2>/dev/null || true
fi

# ── 恢复 DNS，刷新 LuCI ──────────────────────────────────────────────
[ -n "$DNS_INJECTED" ] && /etc/init.d/dnsmasq restart 2>/dev/null || true
rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd restart 2>/dev/null || true

# ── 清理 hotplug 触发器 ──────────────────────────────────────────────
rm -f /etc/hotplug.d/iface/99-install-extras
rm -f "$LOCK"

# ── 只有全部成功才写 DONE_FLAG ───────────────────────────────────────
if [ "$INSTALL_FAIL" -eq 0 ]; then
    touch "$DONE_FLAG"
    log "🎉 install-extras 全部完成"
else
    log "⚠️  有 $INSTALL_FAIL 组包失败，未写 DONE_FLAG，下次 WAN UP 将重试"
    # 重新安装 hotplug 触发器以便重试
    mkdir -p /etc/hotplug.d/iface
    cat > /etc/hotplug.d/iface/99-install-extras << 'HOTPLUGEOF'
#!/bin/sh
[ "$ACTION" = "ifup" ] || exit 0
[ -f /etc/install-extras-done ] && exit 0
case "$INTERFACE" in
    wan|wan6|pppoe-wan) ;;
    *) exit 0 ;;
esac
/usr/lib/install-extras/run.sh &
HOTPLUGEOF
    chmod +x /etc/hotplug.d/iface/99-install-extras
fi
RUNEOF
chmod +x /usr/lib/install-extras/run.sh

# ── 安装 hotplug 触发器 ──────────────────────────────────────────────
mkdir -p /etc/hotplug.d/iface
cat > /etc/hotplug.d/iface/99-install-extras << 'HOTPLUGEOF'
#!/bin/sh
[ "$ACTION" = "ifup" ] || exit 0
[ -f /etc/install-extras-done ] && exit 0
case "$INTERFACE" in
    wan|wan6|pppoe-wan) ;;
    *) exit 0 ;;
esac
/usr/lib/install-extras/run.sh &
HOTPLUGEOF
chmod +x /etc/hotplug.d/iface/99-install-extras

logger -t "96-install-extras" "✅ hotplug 触发器已安装"
exit 0
