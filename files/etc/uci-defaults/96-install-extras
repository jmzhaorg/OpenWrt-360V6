cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
_LT="usb-extras"
_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-usb.lock"
_SD="/etc/install-state"
_MF="/etc/install-usb-mount"

_DOCKER_VERS="28.1.0 27.5.1 26.1.4"
_DOCKER_BASE="https://download.docker.com/linux/static/stable/aarch64"
_AGH_URL="https://static.adguard.com/adguardhome/release/AdGuardHome_linux_arm64.tar.gz"

_DOCKER_EXPECTED_SHA256="${DOCKER_SHA256:-}"
_AGH_EXPECTED_SHA256="${AGH_SHA256:-}"
_STRICT_CHECKSUM="${STRICT_CHECKSUM:-0}"

log() {
    __lm="[$(date '+%H:%M:%S')] $1"
    echo "$__lm"
    echo "$__lm" | logger -t "$_LT"
}

_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { echo "$_mp"; return 0; }
    done
    return 1
}

_is_usb_dev() {
    case "$1" in
        /dev/sd[a-z][0-9]*|/dev/mmcblk[0-9]*p[0-9]*) return 0 ;;
        *) return 1 ;;
    esac
}

_timeout() {
    __tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$__tt" "$@" 2>/dev/null
        return $?
    fi
    "$@" &
    __pid=$!
    __cnt=0
    while [ "$__cnt" -lt "$__tt" ]; do
        kill -0 "$__pid" 2>/dev/null || { wait "$__pid"; return $?; }
        sleep 1
        __cnt=$((__cnt + 1))
    done
    kill -9 "$__pid" 2>/dev/null
    wait "$__pid" 2>/dev/null
    return 124
}

_tar_extract() {
    __tgz="$1"; __dst="$2"; __subdir="$3"
    __tmp="${__dst}.xtmp$$"
    rm -rf "$__tmp"
    mkdir -p "$__tmp" "$__dst" || return 1
    tar xzf "$__tgz" -C "$__tmp" 2>/dev/null || { rm -rf "$__tmp"; return 1; }

    if [ -n "$__subdir" ] && [ -d "$__tmp/$__subdir" ]; then
        __src="$__tmp/$__subdir"
    else
        __src="$__tmp"
    fi

    __moved=0
    for __f in "$__src/"*; do
        [ -e "$__f" ] || continue
        __bn="${__f##*/}"
        rm -rf "$__dst/$__bn"
        mv "$__f" "$__dst/" 2>/dev/null || { rm -rf "$__tmp"; return 1; }
        __moved=$((__moved + 1))
    done
    rm -rf "$__tmp"
    [ "$__moved" -gt 0 ]
}

_wget_retry() {
    __url="$1"; __out="$2"; __min_size="${3:-0}"
    __r=0
    while [ "$__r" -lt 3 ]; do
        wget -q --timeout=120 --tries=1 -O "$__out" "$__url" 2>/dev/null
        if [ -f "$__out" ]; then
            __sz=$(wc -c < "$__out" 2>/dev/null || echo 0)
            if [ "${__sz:-0}" -ge "$__min_size" ] && [ "${__sz:-0}" -gt 0 ]; then
                return 0
            fi
        fi
        rm -f "$__out"
        __r=$((__r + 1))
        [ "$__r" -lt 3 ] && { log "下载失败 (${__r}/3)，重试..."; sleep 3; }
    done
    return 1
}

_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" 2>/dev/null | cut -d' ' -f1
    elif command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha256 "$1" 2>/dev/null | cut -d' ' -f2
    else
        echo ""
    fi
}

_verify_checksum() {
    __file="$1"; __expected="$2"; __name="$3"
    [ -z "$__expected" ] && {
        log "警告: $__name 未配置 SHA256，跳过校验"
        return 0
    }
    __actual=$(_sha256 "$__file")
    [ -z "$__actual" ] && { log "警告: 无法计算 $__name 的 SHA256"; return 0; }
    if [ "$__actual" = "$__expected" ]; then
        log "$__name 校验通过"
        return 0
    fi
    log "错误: $__name 校验和不匹配（期望: $__expected，实际: $__actual）"
    [ "$_STRICT_CHECKSUM" = "1" ] && return 1
    return 0
}

_pkg_install() {
    if command -v apk >/dev/null 2>&1; then
        apk add --no-cache "$@" >/dev/null 2>&1
    elif command -v opkg >/dev/null 2>&1; then
        opkg install "$@" >/dev/null 2>&1
    else
        return 1
    fi
}

# FIX V3.8: 端口探测替代 pgrep，更可靠地判断进程是否真正就绪
_wait_port() {
    __host="$1"; __port="$2"; __max="$3"
    __wi=0
    while [ "$__wi" -lt "$__max" ]; do
        if nc -z "$__host" "$__port" 2>/dev/null; then
            return 0
        fi
        sleep 1
        __wi=$((__wi + 1))
    done
    return 1
}

