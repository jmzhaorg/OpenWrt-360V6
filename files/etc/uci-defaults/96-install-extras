    done
    return 1
}

_log() { echo "[$(date '+%H:%M:%S')] $1"; }

_tar_extract() {
    __tgz="$1"; __dst="$2"; __sub="$3"
    __tmp="${__dst}.xtmp$$"
    rm -rf "$__tmp"; mkdir -p "$__tmp" "$__dst" || return 1
    tar xzf "$__tgz" -C "$__tmp" 2>/dev/null || { rm -rf "$__tmp"; return 1; }
    [ -n "$__sub" ] && [ -d "$__tmp/$__sub" ] && __src="$__tmp/$__sub" || __src="$__tmp"
    __n=0
    for __f in "$__src/"*; do
        [ -e "$__f" ] || continue
        rm -rf "$__dst/${__f##*/}"
        mv "$__f" "$__dst/" 2>/dev/null || { rm -rf "$__tmp"; return 1; }
        __n=$((__n+1))
    done
    rm -rf "$__tmp"
    [ "$__n" -gt 0 ]
}

_USB=$(_get_usb_mount)
[ -z "$_USB" ] && { echo "[ERR] 未找到 U 盘"; exit 1; }

_upgrade_docker() {
    _log "开始升级 Docker..."
    _cur=$(cat "$_USB/docker-bin/version.txt" 2>/dev/null || echo "未知")
    _log "当前版本: $_cur"
    for _dv in $_DOCKER_VERS; do
        _tgz="$_USB/.downloads/docker-${_dv}.tgz"
        _log "下载 Docker ${_dv}..."
        wget -q --timeout=120 --tries=2 -O "${_tgz}.tmp" \
            "$_DOCKER_BASE/docker-${_dv}.tgz" 2>/dev/null
        # gzip 完整性校验（V4.0 优点）
        if [ -f "${_tgz}.tmp" ] && gzip -t "${_tgz}.tmp" 2>/dev/null; then
            mv "${_tgz}.tmp" "$_tgz"
        else
            rm -f "${_tgz}.tmp"
            _log "下载或校验失败，尝试下一版本"
            continue
        fi
        _log "停止 Docker..."
        /etc/init.d/dockerd stop 2>/dev/null; sleep 3
        _log "解压 Docker ${_dv}..."
        if _tar_extract "$_tgz" "$_USB/docker-bin" "docker" && \
           [ -f "$_USB/docker-bin/dockerd" ]; then
            echo "$_dv" > "$_USB/docker-bin/version.txt"
            /etc/init.d/dockerd start 2>/dev/null; sleep 5
            docker info >/dev/null 2>&1 && \
                _log "Docker 升级成功: $_cur → ${_dv}" || \
                _log "Docker 已安装，守护进程初始化中"
            return 0
        fi
        _log "解压失败，尝试下一版本"
    done
    _log "Docker 升级失败"; return 1
}

_upgrade_agh() {
    _log "开始升级 AdGuardHome..."
    _cur=$(cat "$_USB/adguardhome-bin/version.txt" 2>/dev/null || echo "未知")
    _log "当前版本: $_cur"
    _tgz="$_USB/.downloads/AdGuardHome_linux_arm64.tar.gz"
    rm -f "$_tgz"
    _log "下载最新版 AdGuardHome..."
    wget -q --timeout=120 --tries=2 -O "${_tgz}.tmp" "$_AGH_URL" 2>/dev/null
    if [ ! -f "${_tgz}.tmp" ] || ! gzip -t "${_tgz}.tmp" 2>/dev/null; then
        rm -f "${_tgz}.tmp"; _log "下载或校验失败"; return 1
    fi
    mv "${_tgz}.tmp" "$_tgz"
    _log "停止 AGH..."
    /etc/init.d/adguardhome stop 2>/dev/null
    pkill -f AdGuardHome 2>/dev/null; sleep 2
    _log "解压 AdGuardHome..."
    if _tar_extract "$_tgz" "$_USB/adguardhome-bin" "AdGuardHome" && \
       [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
        chmod +x "$_USB/adguardhome-bin/AdGuardHome"
        _new=$("$_USB/adguardhome-bin/AdGuardHome" --version 2>/dev/null | \
            grep -o 'v[0-9.]*' | head -1 || echo "未知")
        echo "$_new" > "$_USB/adguardhome-bin/version.txt"
        /etc/init.d/adguardhome start 2>/dev/null
        _log "AGH 升级成功: $_cur → ${_new}"
        return 0
    fi
    _log "解压失败"; return 1
}

case "$1" in
    --docker) _upgrade_docker ;;
    --agh)    _upgrade_agh ;;
    *)
        echo "用法: 360v6-upgrade --docker | --agh"
        echo ""
        echo "当前版本:"
        echo "  Docker : $(cat "$_USB/docker-bin/version.txt" 2>/dev/null || echo '未安装')"
        echo "  AGH    : $(cat "$_USB/adguardhome-bin/version.txt" 2>/dev/null || echo '未安装')"
        exit 1 ;;
esac
