#!/bin/sh
# 96-install-extras [v6.1]
# 适用：360 V6 / IPQ6000 (ImmortalWrt / ash)
#
# v6.1 核心变更：
#   install-usb.sh 完全放弃 apk --root 方案（ImmortalWrt snapshots 源无 docker/adguardhome）
#   改为直接从官方下载预编译静态二进制：
#     Docker    : https://download.docker.com/linux/static/stable/aarch64/
#     AdGuardHome: https://static.adguard.com/adguardhome/release/
#   其余逻辑沿用 v6.0（锁/自愈/procd/MOUNT_FILE 等）

DONE_FLAG="/etc/install-extras-done"
USB_DONE="/etc/install-usb-done"
STATE_DIR="/etc/install-state"
MOUNT_FILE="/etc/install-usb-mount"

# 版本配置（升级时只改这里）
DOCKER_VER="29.3.0"
AGH_VER="v0.107.74"

DOCKER_URL="https://download.docker.com/linux/static/stable/aarch64/docker-${DOCKER_VER}.tgz"
AGH_URL="https://static.adguard.com/adguardhome/release/AdGuardHome_linux_arm64.tar.gz"

mkdir -p "$STATE_DIR" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block \
         /etc/dbus-1 /etc/profile.d /etc/crontabs

_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

# ====================================================================
# 模块 0：360v6-status
# ====================================================================
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }
STATE_DIR="/etc/install-state"

echo "=== 360 V6 状态 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo ""
[ -f /etc/install-extras-done ] && echo "[OK] 基础环境：完成" || echo "[..] 基础环境：待触发"
p1=$(cat "$STATE_DIR/phase1-failures" 2>/dev/null || echo 0)
[ "$p1" -gt 0 ] && echo "     失败次数: $p1/3"
[ -f /etc/install-usb-done ] && echo "[OK] 重型应用：完成" || echo "[..] 重型应用：待 U 盘"
p2=$(cat "$STATE_DIR/phase2-failures" 2>/dev/null || echo 0)
[ "$p2" -gt 0 ] && echo "     失败次数: $p2/3"
echo ""
df -h /overlay 2>/dev/null | awk 'NR==2{print "Flash : "$3" / "$2" ("$5")"}'
free 2>/dev/null | awk '/Mem:/{printf "Mem   : %dMB used / %dMB total\n",$3/1024,$2/1024}'
echo ""
USB_MP=""
for mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
    _is_mounted "$mp" && { echo "USB   : $mp (已挂载)"; USB_MP="$mp"; }
done
[ -z "$USB_MP" ] && echo "USB   : 未检测到"
[ -f /etc/install-usb-mount ] && echo "PATH  : $(cat /etc/install-usb-mount)"
grep -q swapfile /proc/swaps 2>/dev/null && echo "Swap  : swapfile 已激活"
echo ""
docker info >/dev/null 2>&1      && echo "[OK] Docker      : 运行中" || echo "[--] Docker      : 未启动"
pgrep AdGuardHome >/dev/null 2>&1 && echo "[OK] AdGuardHome : 运行中" || echo "[--] AdGuardHome : 未启动"
echo ""
echo "手动重跑基础: rm -f /etc/install-extras-done $STATE_DIR/phase1-failures && /usr/lib/install-extras/run.sh"
echo "手动重跑重型: rm -f /etc/install-usb-done   $STATE_DIR/phase2-failures && /usr/lib/install-extras/install-usb.sh"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ====================================================================
# 模块 A：install-usb.sh（Phase 2：二进制下载方式）
# ====================================================================
cat > /usr/lib/install-extras/install-usb.sh << USBEOF
#!/bin/sh
LOG_TAG="usb"
USB_DONE="/etc/install-usb-done"
LOCK="/tmp/install-usb.lock"
STATE_DIR="/etc/install-state"
MOUNT_FILE="/etc/install-usb-mount"

# 版本 / URL（与外层脚本同步）
DOCKER_VER="${DOCKER_VER}"
AGH_VER="${AGH_VER}"
DOCKER_URL="${DOCKER_URL}"
AGH_URL="${AGH_URL}"

log() { echo "[\$(date '+%H:%M:%S')] \$1" | logger -t "\$LOG_TAG"; }
_is_mounted() { grep -q "^[^ ]* \$1 " /proc/mounts 2>/dev/null; }

mkdir -p "\$STATE_DIR"

# ── 自愈模式 ──────────────────────────────────────────────────────
if [ "\${1:-}" = "--self-heal" ]; then
    [ -f "\$USB_DONE" ] && exit 0
    __sf=\$(cat "\$STATE_DIR/phase2-failures" 2>/dev/null || echo 0)
    [ "\${__sf:-0}" -ge 3 ] && exit 0
    if [ -f "\$LOCK" ]; then
        _pid=\$(cat "\$LOCK" 2>/dev/null)
        kill -0 "\$_pid" 2>/dev/null && exit 0
        log "🔧 清理残留锁 (旧pid=\$_pid)"
        rm -f "\$LOCK"
    fi
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "\$_mp" && { log "🔧 自愈触发: \$_mp"; /usr/lib/install-extras/install-usb.sh "\$_mp" &; exit 0; }
    done
    exit 0
fi

# ── 幂等 / 锁 ────────────────────────────────────────────────────
[ -f "\$USB_DONE" ] && { log "ℹ️ 已完成，跳过"; exit 0; }
trap 'rm -f "\$LOCK"' EXIT INT TERM
if [ -f "\$LOCK" ]; then
    _pid=\$(cat "\$LOCK" 2>/dev/null)
    kill -0 "\$_pid" 2>/dev/null && { log "⚠️ 运行中 (pid=\$_pid)，跳过"; exit 0; }
    log "🔧 清理残留锁 (旧pid=\$_pid)"; rm -f "\$LOCK"
fi
echo \$\$ > "\$LOCK"

__fail=\$(cat "\$STATE_DIR/phase2-failures" 2>/dev/null || echo 0)
[ "\${__fail:-0}" -ge 3 ] && { log "❌ 失败次数过多，停止重试"; exit 1; }

# ── 确定 U 盘挂载点 ──────────────────────────────────────────────
USB_MOUNT="\${1:-}"
case "\$USB_MOUNT" in --*) USB_MOUNT="" ;; esac
[ -n "\$USB_MOUNT" ] && ! _is_mounted "\$USB_MOUNT" && USB_MOUNT=""
if [ -z "\$USB_MOUNT" ]; then
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "\$_mp" && { USB_MOUNT="\$_mp"; break; }
    done
fi
[ -z "\$USB_MOUNT" ] && USB_MOUNT=\$(grep -E '^/dev/sd[a-z][0-9]* ' /proc/mounts 2>/dev/null | head -1 | awk '{print \$2}')
if [ -z "\$USB_MOUNT" ]; then
    log "❌ 未找到 U 盘挂载点"
    echo \$((\$__fail + 1)) > "\$STATE_DIR/phase2-failures"; exit 1
fi
echo "\$USB_MOUNT" > "\$MOUNT_FILE"
log "▶ 重型应用部署 | U盘: \$USB_MOUNT | Docker:\$DOCKER_VER AGH:\$AGH_VER"

# ── 下载目录 / TMPDIR ────────────────────────────────────────────
DL_DIR="\$USB_MOUNT/.downloads"
export TMPDIR="\$USB_MOUNT/.tmp"
mkdir -p "\$DL_DIR" "\$TMPDIR"

# ── 空间预检（≥ 1GB，二进制比 apk --root 小很多）───────────────
_avail=\$(df -k "\$USB_MOUNT" 2>/dev/null | awk 'NR==2{print \$4}')
if [ "\${_avail:-0}" -lt 1048576 ]; then
    log "⚠️ U 盘空间不足 (\${_avail:-0}KB < 1GB)"
    echo \$((\$__fail + 1)) > "\$STATE_DIR/phase2-failures"; exit 1
fi

# ── DNS 保护 ─────────────────────────────────────────────────────
__dns_old=\$(cat /etc/resolv.conf 2>/dev/null)
[ -z "\$__dns_old" ] && __dns_old="nameserver 127.0.0.1"
printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
trap 'rm -f "\$LOCK"; printf "%s\n" "\$__dns_old" > /etc/resolv.conf' EXIT INT TERM

echo "10" > /proc/sys/vm/swappiness 2>/dev/null

# ── Swap ─────────────────────────────────────────────────────────
SWAPFILE="\$USB_MOUNT/swapfile"
if ! grep -q swapfile /proc/swaps 2>/dev/null; then
    if [ ! -f "\$SWAPFILE" ]; then
        log "⏳ 创建 256MB Swap..."
        dd if=/dev/zero of="\${SWAPFILE}.tmp" bs=1M count=256 2>/dev/null && {
            mv "\${SWAPFILE}.tmp" "\$SWAPFILE"; sync
            chmod 600 "\$SWAPFILE"; mkswap "\$SWAPFILE" >/dev/null 2>&1
            log "✅ Swap 文件已创建"
        } || rm -f "\${SWAPFILE}.tmp"
    fi
    [ -f "\$SWAPFILE" ] && swapon "\$SWAPFILE" 2>/dev/null && {
        grep -qF "\$SWAPFILE" /etc/fstab 2>/dev/null || echo "\$SWAPFILE none swap sw 0 0" >> /etc/fstab
        log "✅ Swap 已激活"
    }
fi

# ── 下载函数（wget，失败重试 3 次）──────────────────────────────
_download() {
    _url="\$1"; _out="\$2"; _desc="\$3"
    log "⬇️ 下载 \$_desc ..."
    _i=1
    while [ "\$_i" -le 3 ]; do
        wget -q --timeout=120 --tries=1 -O "\${_out}.tmp" "\$_url" 2>/dev/null && {
            mv "\${_out}.tmp" "\$_out"
            log "✅ 下载完成: \$_desc"
            return 0
        }
        log "⚠️ 下载失败 (\$_i/3): \$_desc"
        rm -f "\${_out}.tmp"
        _i=\$((\$_i + 1))
        sleep 5
    done
    log "❌ 下载失败: \$_desc"
    return 1
}

# ====================================================================
# Docker 静态二进制安装
# ====================================================================
log "📦 部署 Docker \$DOCKER_VER ..."
DD="\$USB_MOUNT/docker-data"
DB="\$USB_MOUNT/docker-bin"
mkdir -p "\$DD" "\$DB" /etc/docker

__dok=0
DOCKER_TGZ="\$DL_DIR/docker-\${DOCKER_VER}.tgz"

# 跳过已下载的文件
if [ ! -f "\$DOCKER_TGZ" ]; then
    _download "\$DOCKER_URL" "\$DOCKER_TGZ" "Docker \$DOCKER_VER" || {
        log "❌ Docker 下载失败，跳过"
    }
fi

if [ -f "\$DOCKER_TGZ" ]; then
    log "📂 解压 Docker..."
    tar -xzf "\$DOCKER_TGZ" -C "\$DB" --strip-components=1 2>/dev/null && {
        # 符号链接到 overlay 可写层
        mkdir -p /overlay/upper/usr/bin
        for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc; do
            [ -f "\$DB/\$_b" ] && ln -sf "\$DB/\$_b" "/overlay/upper/usr/bin/\$_b" 2>/dev/null || true
        done

        cat > /etc/docker/daemon.json << DJSON
{
  "data-root": "\$DD",
  "storage-driver": "overlay2",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"}
}
DJSON

        # procd init 脚本（读 MOUNT_FILE，不运行时重新扫描）
        cat > /etc/init.d/dockerd << 'DINIT'
#!/bin/sh /etc/rc.common
START=99; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-usb-done ] || return 0
    M=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$M" ] && [ -f "$M/docker-bin/dockerd" ] || return 1
    procd_open_instance
    procd_set_param command "$M/docker-bin/dockerd" --config-file /etc/docker/daemon.json
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 3
    procd_close_instance
}
stop_service() { pkill dockerd 2>/dev/null; pkill containerd 2>/dev/null; return 0; }
DINIT
        chmod +x /etc/init.d/dockerd
        /etc/init.d/dockerd enable 2>&1 | logger -t "\$LOG_TAG"
        /etc/init.d/dockerd start  2>&1 | logger -t "\$LOG_TAG"

        # 等待 dockerd 就绪（最长 30 秒）
        _i=1
        while [ "\$_i" -le 15 ]; do
            docker info >/dev/null 2>&1 && { __dok=1; break; }
            sleep 2; _i=\$((\$_i + 1))
        done
        [ "\$__dok" -eq 1 ] \
            && log "✅ Docker \$DOCKER_VER 已启动" \
            || log "⚠️ Docker 启动超时（稍后可能就绪）"
    } || log "❌ Docker 解压失败"
fi

# ====================================================================
# AdGuardHome 静态二进制安装
# ====================================================================
log "📦 部署 AdGuardHome \$AGH_VER ..."
AB="\$USB_MOUNT/adguardhome-bin"
AD="\$USB_MOUNT/adguardhome-data"
AC="\$USB_MOUNT/adguardhome-config"
mkdir -p "\$AB" "\$AD" "\$AC"

__aok=0
AGH_TGZ="\$DL_DIR/AdGuardHome_linux_arm64.tar.gz"

if [ ! -f "\$AGH_TGZ" ]; then
    _download "\$AGH_URL" "\$AGH_TGZ" "AdGuardHome \$AGH_VER" || {
        log "❌ AdGuardHome 下载失败，跳过"
    }
fi

if [ -f "\$AGH_TGZ" ]; then
    log "📂 解压 AdGuardHome..."
    tar -xzf "\$AGH_TGZ" -C "\$AB" --strip-components=1 2>/dev/null && \
    [ -f "\$AB/AdGuardHome" ] && {
        chmod +x "\$AB/AdGuardHome"
        mkdir -p /overlay/upper/usr/bin
        ln -sf "\$AB/AdGuardHome" "/overlay/upper/usr/bin/AdGuardHome" 2>/dev/null || true

        # 配置 / 数据迁移（仅首次）
        [ ! -f "\$AC/AdGuardHome.yaml" ] && [ -f "/etc/adguardhome/AdGuardHome.yaml" ] && \
            cp -a /etc/adguardhome/. "\$AC/" 2>/dev/null && log "✅ AGH 配置已迁移"
        [ -z "\$(ls -A "\$AD" 2>/dev/null)" ] && [ -d "/var/lib/adguardhome" ] && \
            cp -a /var/lib/adguardhome/. "\$AD/" 2>/dev/null && log "✅ AGH 数据已迁移"

        cat > /etc/init.d/adguardhome << 'AINIT'
#!/bin/sh /etc/rc.common
START=98; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-usb-done ] || return 0
    M=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$M" ] && [ -f "$M/adguardhome-bin/AdGuardHome" ] || return 1
    procd_open_instance
    procd_set_param command "$M/adguardhome-bin/AdGuardHome" \
        --config "$M/adguardhome-config/AdGuardHome.yaml" \
        --work-dir "$M/adguardhome-data"
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 3
    procd_close_instance
}
stop_service() { pkill AdGuardHome 2>/dev/null; return 0; }
AINIT
        chmod +x /etc/init.d/adguardhome
        /etc/init.d/adguardhome enable  >/dev/null 2>&1
        /etc/init.d/adguardhome restart >/dev/null 2>&1
        sleep 3
        pgrep -x AdGuardHome >/dev/null 2>&1 && __aok=1
        [ "\$__aok" -eq 1 ] \
            && log "✅ AdGuardHome \$AGH_VER 已启动" \
            || log "⚠️ AGH 进程未就绪"
    } || log "❌ AdGuardHome 解压失败"
fi

# ── 刷新 LuCI ────────────────────────────────────────────────────
rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd restart >/dev/null 2>&1

# ── 收尾 ─────────────────────────────────────────────────────────
if [ "\$__dok" -eq 1 ] || [ "\$__aok" -eq 1 ]; then
    touch "\$USB_DONE"
    rm -f "\$STATE_DIR/phase2-failures"
    _ds=\$([ "\$__dok" -eq 1 ] && echo "OK" || echo "FL")
    _as=\$([ "\$__aok" -eq 1 ] && echo "OK" || echo "FL")
    log "🎉 重型应用完成 [Docker:\$_ds AGH:\$_as]"
    exit 0
fi
echo \$((\$__fail + 1)) > "\$STATE_DIR/phase2-failures"
log "❌ 全部失败，等待自愈重试 (\$((\$__fail + 1))/3)"
exit 1
USBEOF
chmod +x /usr/lib/install-extras/install-usb.sh

# ====================================================================
# 模块 B：run.sh（Phase 1 基础环境，与 v6.0 相同）
# ====================================================================
cat > /usr/lib/install-extras/run.sh << 'RUNEOF'
#!/bin/sh
LOG_TAG="main"
DONE="/etc/install-extras-done"
USB_DONE="/etc/install-usb-done"
LOCK="/tmp/install-main.lock"
STATE_DIR="/etc/install-state"

log() { echo "[$(date '+%H:%M:%S')] $1" | logger -t "$LOG_TAG"; }
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

mkdir -p "$STATE_DIR"
[ -f "$DONE" ] && { log "ℹ️ 基础已完成，跳过"; exit 0; }

trap 'rm -f "$LOCK"' EXIT INT TERM
if [ -f "$LOCK" ]; then
    _pid=$(cat "$LOCK" 2>/dev/null)
    kill -0 "$_pid" 2>/dev/null && { log "⚠️ 运行中 (pid=$_pid)，跳过"; exit 0; }
    log "🔧 清理残留锁 (旧pid=$_pid)"; rm -f "$LOCK"
fi
echo $$ > "$LOCK"

__fail=$(cat "$STATE_DIR/phase1-failures" 2>/dev/null || echo 0)
[ "${__fail:-0}" -ge 3 ] && { log "❌ 失败过多，暂停自动重试"; exit 1; }

log "▶ v6.1 基础环境启动"
sleep 10

for _f in /etc/apk/repositories.d/*.list; do
    [ -f "$_f" ] && sed '/\/video\//d' "$_f" > "${_f}.tmp" && mv "${_f}.tmp" "$_f"
done 2>/dev/null

NET_OK=0; _i=1
while [ "$_i" -le 36 ]; do
    ping -c1 -W2 223.5.5.5 >/dev/null 2>&1 && { NET_OK=1; break; }
    ping -c1 -W2 8.8.8.8   >/dev/null 2>&1 && { NET_OK=1; break; }
    sleep 5; _i=$((_i + 1))
done
[ "$NET_OK" -eq 0 ] && { log "❌ 网络不可达"; echo $((__fail + 1)) > "$STATE_DIR/phase1-failures"; exit 1; }
log "✅ 网络就绪"

__dns_old=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_old" ] && __dns_old="nameserver 127.0.0.1"
printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
trap 'rm -f "$LOCK"; printf "%s\n" "$__dns_old" > /etc/resolv.conf; /etc/init.d/dnsmasq restart >/dev/null 2>&1; log "✅ DNS 已恢复"' EXIT INT TERM
log "✅ 临时 DNS 已注入"

FLASH=$(df /overlay 2>/dev/null | awk 'NR==2{print $4}')
log "📊 Flash 剩余: ${FLASH:-?}KB"
[ "${FLASH:-0}" -lt 20480 ] && { log "❌ Flash 不足 20MB"; echo $((__fail + 1)) > "$STATE_DIR/phase1-failures"; exit 1; }

__apk_update() {
    _t=$(mktemp /tmp/apk.XXXXXX)
    apk update > "$_t" 2>&1; cat "$_t" | logger -t "$LOG_TAG"
    _n=$(grep -oE 'OK: [0-9]+ distinct' "$_t" 2>/dev/null | grep -oE '[0-9]+' | head -1)
    rm -f "$_t"; [ "${_n:-0}" -gt 800 ] && return 0
    log "⚠️ HTTPS 不足，切换 HTTP"
    for _f in /etc/apk/repositories.d/*.list; do
        [ -f "$_f" ] && sed 's|https://|http://|g' "$_f" > "${_f}.tmp" && mv "${_f}.tmp" "$_f"
    done 2>/dev/null
    _t=$(mktemp /tmp/apk.XXXXXX)
    apk update > "$_t" 2>&1; cat "$_t" | logger -t "$LOG_TAG"
    _n=$(grep -oE 'OK: [0-9]+ distinct' "$_t" 2>/dev/null | grep -oE '[0-9]+' | head -1)
    rm -f "$_t"; [ "${_n:-0}" -gt 800 ]
}
__apk_update || { log "❌ apk update 失败"; echo $((__fail + 1)) > "$STATE_DIR/phase1-failures"; exit 1; }
log "✅ apk update 成功"

__inst_fail=0
__inst() {
    _t=$(mktemp /tmp/apk.XXXXXX); log "📦 $*"
    apk add --no-cache "$@" > "$_t" 2>&1; _r=$?
    cat "$_t" | logger -t "$LOG_TAG"; rm -f "$_t"
    [ "$_r" -ne 0 ] && { log "❌ 失败: $*"; __inst_fail=$((__inst_fail + 1)); }
    return $_r
}

__inst bash htop lsblk smartmontools fdisk
[ "${FLASH:-0}" -ge 25000 ] \
    && __inst samba4-server luci-app-samba4 luci-i18n-samba4-zh-cn \
    || log "ℹ️ Flash 不足 25MB，跳过 Samba"

/etc/init.d/avahi-daemon stop >/dev/null 2>&1; sleep 1
/etc/init.d/dbus stop  >/dev/null 2>&1; sleep 1
/etc/init.d/dbus start >/dev/null 2>&1; sleep 2
/etc/init.d/avahi-daemon start >/dev/null 2>&1
log "✅ dbus/avahi 已重载"

rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd restart >/dev/null 2>&1

if [ "$__inst_fail" -ne 0 ]; then
    log "⚠️ $__inst_fail 组包失败，下次 WAN UP 自动重试"
    echo $((__fail + 1)) > "$STATE_DIR/phase1-failures"; exit 1
fi

touch "$DONE"
rm -f "$STATE_DIR/phase1-failures"
FLASH_FINAL=$(df /overlay 2>/dev/null | awk 'NR==2{print $5}' | tr -d '%')
log "🎉 基础环境完成！Flash: ${FLASH_FINAL:-?}%"

[ ! -f "$USB_DONE" ] && {
    MP=""
    for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_m" && { MP="$_m"; break; }
    done
    [ -z "$MP" ] && MP=$(grep -E '^/dev/sd[a-z][0-9]* ' /proc/mounts 2>/dev/null | head -1 | awk '{print $2}')
    if [ -n "$MP" ]; then
        log "✅ U 盘已挂载: $MP，触发重型应用..."
        /usr/lib/install-extras/install-usb.sh "$MP" &
    else
        log "ℹ️ U 盘未挂载，等待 hotplug 哨兵触发"
    fi
}
RUNEOF
chmod +x /usr/lib/install-extras/run.sh

# ====================================================================
# 模块 C：WAN hotplug
# ====================================================================
cat > /etc/hotplug.d/iface/96-install-extras << 'IFACEEOF'
#!/bin/sh
[ "$ACTION" = "ifup" ] || exit 0
case "$INTERFACE" in wan|wan6|pppoe-wan) ;; *) exit 0 ;; esac
[ -f /etc/install-extras-done ] && exit 0
logger -t "hotplug" "🌐 WAN 上线，触发基础环境"
/usr/lib/install-extras/run.sh &
IFACEEOF
chmod +x /etc/hotplug.d/iface/96-install-extras

# ====================================================================
# 模块 D：U 盘 hotplug
# ====================================================================
cat > /etc/hotplug.d/block/96-install-usb << 'BLOCKEOF'
#!/bin/sh
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }
[ "$ACTION" = "add" ]           || exit 0
[ -f /etc/install-usb-done ]    && exit 0
[ -f /etc/install-extras-done ] || exit 0
logger -t "hotplug" "💾 U 盘插入: DEVNAME=${DEVNAME:-?}"
MP=""; _i=1
while [ "$_i" -le 15 ]; do
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { MP="$_mp"; break 2; }
    done
    MP=$(grep -E '^/dev/sd[a-z][0-9]* ' /proc/mounts 2>/dev/null | head -1 | awk '{print $2}')
    [ -n "$MP" ] && break
    sleep 2; _i=$((_i + 1))
done
[ -z "$MP" ] && { logger -t "hotplug" "⚠️ 挂载点未就绪，跳过"; exit 1; }
pgrep -f "install-usb.sh" >/dev/null 2>&1 && { logger -t "hotplug" "⚠️ 已在运行，跳过"; exit 0; }
logger -t "hotplug" "💾 U 盘就绪: $MP，触发重型应用"
/usr/lib/install-extras/install-usb.sh "$MP" &
BLOCKEOF
chmod +x /etc/hotplug.d/block/96-install-usb

# ====================================================================
# 模块 E：自愈定时任务
# ====================================================================
if ! grep -q "self-heal" /etc/crontabs/root 2>/dev/null; then
    echo "*/5 * * * * PATH=/usr/bin:/bin:/usr/sbin:/sbin /usr/lib/install-extras/install-usb.sh --self-heal 2>&1 | logger -t self-heal" \
        >> /etc/crontabs/root
    /etc/init.d/cron restart 2>/dev/null || true
fi

# ====================================================================
# 首次触发
# ====================================================================
[ ! -f /etc/install-extras-done ] && /usr/lib/install-extras/run.sh &

logger -t "install-extras" "✅ v6.1 就绪 | Docker:${DOCKER_VER} AGH:${AGH_VER}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "🚀 v6.1 部署完成"
echo "   Docker : ${DOCKER_VER}"
echo "   AGH    : ${AGH_VER}"
echo "📊 状态 : 360v6-status"
echo "📋 日志 : logread -f | grep -E 'main|usb|hotplug|self-heal'"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
exit 0
