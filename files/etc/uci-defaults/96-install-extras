#!/bin/sh
# 96-install-extras [V3.7]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash / ImmortalWrt / busybox ash)

# ══════════════════════════════════════════════════════════════
# DEBUG 模式
# ══════════════════════════════════════════════════════════════
[ -n "$DEBUG" ] && set -x

# ══════════════════════════════════════════════════════════════
# 全局配置 + 日志缓冲
# ══════════════════════════════════════════════════════════════
_SD="/etc/install-state"
mkdir -p "$_SD" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block \
         /etc/dbus-1 /etc/dbus-1/system.d
# 注：/etc/crontabs 已移除（未使用）

__log_buf=""
__log_count=0
__log_tag="install-main"

log() {
    __msg="[$(date '+%H:%M:%S')] $1"
    [ -n "$DEBUG" ] && echo "$__msg" >&2
    __log_buf="${__log_buf}${__msg}
"
    __log_count=$((__log_count + 1))
    [ "$__log_count" -ge 10 ] && __flush_logs
}

__flush_logs() {
    [ -n "$__log_buf" ] && printf "%s" "$__log_buf" | logger -t "$__log_tag"
    __log_buf=""
    __log_count=0
}

trap '__flush_logs' EXIT INT TERM

echo "1048576" > /proc/sys/net/core/rmem_max 2>/dev/null
echo "1048576" > /proc/sys/net/core/wmem_max 2>/dev/null
echo "32768"   > /proc/sys/net/nf_conntrack_max 2>/dev/null

# ──────────────────────────────────────────────
# 公共函数：_get_usb_mount
# ──────────────────────────────────────────────
_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        if grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null; then
            echo "$_mp"
            return 0
        fi
    done
    return 1
}

# ──────────────────────────────────────────────
# 公共函数：_timeout（busybox 兼容）
# ──────────────────────────────────────────────
_timeout() {
    __tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$__tt" "$@" 2>/dev/null
        return $?
    fi
    "$@" &
    __pid=$!
    __cnt=0
    while [ "$__cnt" -lt "$__tt" ]; do
        kill -0 "$__pid" 2>/dev/null || { wait "$__pid"; return $?; }
        sleep 1
        __cnt=$((__cnt + 1))
    done
    kill -9 "$__pid" 2>/dev/null
    wait "$__pid" 2>/dev/null
    return 124
}

# ──────────────────────────────────────────────
# 公共函数：_sha256
# ──────────────────────────────────────────────
_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" 2>/dev/null | cut -d' ' -f1
    elif command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha256 "$1" 2>/dev/null | cut -d' ' -f2
    else
        echo ""
    fi
}

# ══════════════════════════════════════════════════════════════
# 模块 0：360v6-status
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-status << 'STATUSEOF'
