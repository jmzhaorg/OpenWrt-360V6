# Hotplug: iface（V5.0 = V4.0：60s 冷却 + Phase 1 完成后不再触发）
# ============================================================
cat > /etc/hotplug.d/iface/96-install-extras << 'IFACEEOF'
#!/bin/sh
[ "${ACTION:-}" = "ifup" ] || exit 0
case "${INTERFACE:-}" in wan|wan6|pppoe-wan) ;; *) exit 0 ;; esac

_SD="/etc/install-state"
mkdir -p "$_SD"

# 60s 冷却防 WAN 抖动（V4.0 优点）
_last=$(cat "$_SD/last-iface-trigger" 2>/dev/null || echo 0)
_now=$(awk '{printf "%d",$1}' /proc/uptime 2>/dev/null || echo 0)
_el=$((_now - _last))
[ "$_el" -lt 60 ] && [ "$_el" -gt 0 ] && exit 0
echo "$_now" > "$_SD/last-iface-trigger"

/usr/lib/install-extras/run.sh &
IFACEEOF
chmod +x /etc/hotplug.d/iface/96-install-extras

# ============================================================
# Hotplug: block（V5.0 融合：remove 优雅停服 + 设备合法性校验 + 路由清晰）
# ============================================================
cat > /etc/hotplug.d/block/96-install-usb << 'BLOCKEOF'
#!/bin/sh
case "${DEVNAME:-}" in sd[a-z]*|mmcblk[0-9]*) ;; *) exit 0 ;; esac

# USB 移除 → 优雅停服（V2.0 + V4.0 共同优点）
if [ "${ACTION:-}" = "remove" ]; then
    logger -t "usb-extras" "U 盘移除，停止依赖服务"
    /etc/init.d/dockerd stop 2>/dev/null
    /etc/init.d/adguardhome stop 2>/dev/null
    rm -f /etc/install-usb-done 2>/dev/null
    exit 0
fi

[ "${ACTION:-}" = "add" ] || exit 0

# 等待挂载（最多 24s）
_mp=""; _i=1
while [ "$_i" -le 12 ]; do
    for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_m " /proc/mounts 2>/dev/null && { _mp="$_m"; break 2; }
    done
    sleep 2; _i=$((_i+1))
done
[ -n "$_mp" ] || { logger -t "usb-extras" "U 盘挂载超时"; exit 1; }

# 核心路由（V5.0：.install-done 优先走 restore.sh，V2.0 架构）
if [ -f "$_mp/.install-done" ]; then
    logger -t "usb-restore" "恢复模式: $_mp"
    /usr/lib/install-extras/restore.sh "$_mp" &
else
    # 全新部署需要 Phase 1 完成（V4.0 严格性）
    [ -f /etc/install-extras-done ] || { logger -t "usb-extras" "等待 Phase 1 完成"; exit 0; }
    logger -t "usb-extras" "全新部署: $_mp"
    /usr/lib/install-extras/install-usb.sh "$_mp" &
fi
BLOCKEOF
chmod +x /etc/hotplug.d/block/96-install-usb

# ============================================================
# 完成
# ============================================================
rm -f /etc/uci-defaults/96-install-extras

log "360 V6 部署脚本 V${_VERSION} 安装完成"
__flush_logs

echo ""
echo "=========================================="
echo "  360 V6 部署脚本 V${_VERSION} 已安装"
echo "=========================================="
echo ""
echo "架构："
echo "  USB 有 .install-done → restore.sh 快速恢复 (~5秒)"
echo "  USB 无 .install-done → install-usb.sh 全新部署"
echo ""
echo "首次部署流程："
echo "  1. 格式化 U 盘为 ext4 并插入路由器"
echo "  2. 等待自动部署（约 5-10 分钟，看 logread -f）"
echo "  3. 访问 http://192.168.2.1:3000 完成 AGH 向导"
echo "  4. AGH_USER=admin AGH_PASS=密码 agh-finalize"
echo "  5. 360v6-status 验证状态"
echo ""
echo "重启/热插拔后：自动快速恢复（~5秒），无需手动操作"
echo ""
echo "管理命令："
echo "  360v6-status                     查看状态"
echo "  360v6-health [--fix]             健康检查 / 自动修复"
echo "  360v6-tune --mode=...            性能调节"
echo "  360v6-upgrade --docker|--agh     升级组件"
echo "  agh-finalize                     AGH 初始化完成"
echo "  360v6-uninstall [--yes]          卸载全部"
echo ""
