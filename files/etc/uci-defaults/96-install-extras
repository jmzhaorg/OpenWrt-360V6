        _fix_action "禁用 dnsmasq DNS" _fix_disable_dnsmasq
        _errs=$((_errs + 1))
    else
        _ok "DNS 分配正常"
    fi
fi

echo ""
[ "$_errs" -eq 0 ] && echo "健康检查完成，无异常" || echo "发现 ${_errs} 个问题"
HEALTHEOF
