#!/bin/sh
# ============================================================
# 96-install-extras [V5.0]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash / ImmortalWrt / busybox ash)
#
# 架构（融合 V2.0 + V4.0 各取所长）：
#   USB 有 .install-done → restore.sh 快速恢复（~5秒，无网络无下载）
#   USB 无 .install-done → install-usb.sh 全新部署
#   restore.sh 独立脚本，不依赖 install-usb.sh（V2.0 架构优点）
#   USB 标记写时间戳，方便追溯（V4.0 优点）
#   服务顺序：swap → Docker(cgroup) → AGH(网络)
#
# 变更说明 V5.0：
#   1. restore.sh 独立脚本（取自 V2.0），轻量无下载
#   2. .install-done 写时间戳（取自 V4.0）
#   3. install-usb.sh 加 SHA256 可选校验、文件系统类型检测（取自 V4.0）
#   4. 自愈模式 --self-heal（取自 V4.0）
#   5. 360v6-status 完善 Wi-Fi/IPv6/DNS 统计（取自 V4.0）
#   6. 360v6-health DNS 冲突检测用 ss+netstat 双路（取自 V4.0）
#   7. 360v6-upgrade 加 gzip 完整性校验（取自 V4.0）
#   8. 360v6-uninstall 从 /proc/swaps 读 swap 路径（取自 V4.0）
#   9. agh-finalize 凭证持久化 + trap 修复（取自 V4.0）
#  10. AGH/dockerd init.d 只依赖 U 盘文件（取自 V4.0）
#  11. dockerd init.d 补 PATH 环境变量（取自 V4.0）
#  12. block hotplug remove 优雅停服 + USB 设备合法性校验（两版融合）
#  13. iface hotplug 60s 冷却防 WAN 抖动（取自 V4.0）
#  14. Docker 防火墙 nftables/iptables 自动检测（取自 V4.0）
#  15. U 盘持久化日志 + 7天自动清理（取自 V4.0）
# ============================================================

[ -n "$DEBUG" ] && set -x

_VERSION="5.0"
_SD="/etc/install-state"
_USB_MOUNT_FILE="/etc/install-usb-mount"
mkdir -p "$_SD" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block

__log_buf=""
__log_count=0
__log_tag="install-main"

log() {
    __msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    [ -n "$DEBUG" ] && echo "$__msg" >&2
    __log_buf="${__log_buf}${__msg}
"
    __log_count=$((__log_count + 1))
    [ "$__log_count" -ge 10 ] && __flush_logs
}

__flush_logs() {
    [ -n "$__log_buf" ] && printf "%s" "$__log_buf" | logger -t "$__log_tag"
    __log_buf=""
    __log_count=0
}

trap '__flush_logs' EXIT INT TERM

# 系统基础调优
echo "1048576" > /proc/sys/net/core/rmem_max 2>/dev/null
echo "1048576" > /proc/sys/net/core/wmem_max 2>/dev/null
echo "32768"   > /proc/sys/net/nf_conntrack_max 2>/dev/null

# ============================================================
# 360v6-status（V5.0 = V4.0 完善版 + V2.0 AGH 统计逻辑）
# ============================================================
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"
_VERSION="5.0"

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

if [ -t 1 ]; then
    _G="\033[32m"; _R="\033[31m"; _Y="\033[33m"; _B="\033[36m"
    _C="\033[34m"; _N="\033[0m"; _BOLD="\033[1m"
else
    _G=""; _R=""; _Y=""; _B=""; _C=""; _N=""; _BOLD=""
fi

_ok()   { printf "${_G}[OK]${_N}  %s\n" "$1"; }
_warn() { printf "${_Y}[..]${_N}  %s\n" "$1"; }
_err()  { printf "${_R}[!!]${_N}  %s\n" "$1"; }
_info() { printf "      ${_B}%s${_N}\n" "$1"; }
_hint() { printf "      ${_Y}提示: %s${_N}\n" "$1"; }
_title(){ printf "\n${_C}${_BOLD}%s${_N}\n" "$1"; }

_USB=$(_get_usb_mount)
_USB_DONE="${_USB}/.install-done"

printf "${_BOLD}================================${_N}\n"
printf "${_BOLD}    360 V6 状态报告 V${_VERSION}${_N}\n"
printf "    时间: $(date '+%Y-%m-%d %H:%M:%S')\n"
printf "${_BOLD}================================${_N}\n"

# ── 部署状态 ──────────────────────────────────
_title "【部署状态】"
if [ -n "$_USB" ]; then
    if [ -f "$_USB_DONE" ]; then
        _ok "USB 部署: 已完成（$(cat "$_USB_DONE" 2>/dev/null)）"
        _info "恢复模式: 下次启动约 5 秒自动恢复"
    else
        _warn "USB 部署: 未完成（等待全新部署）"
    fi
    if [ -f "$_USB/.agh-finalized" ]; then
        _ok "AGH 配置: 已完成（agh-finalize 已执行）"
    elif [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
        _warn "AGH 配置: 待完成（运行 agh-finalize）"
    fi
else
    _warn "未检测到 U 盘"
fi

if [ -f /etc/install-extras-done ]; then
    _ok "基础组件: 已安装（$(cat /etc/install-extras-done 2>/dev/null)）"
else
    _warn "基础组件: 等待首次 WAN 连接"
fi

# ── 网络状态 ──────────────────────────────────
_title "【网络】"
_wan_ip=$(ip -4 addr show dev wan 2>/dev/null | \
    awk '/inet /{gsub(/\/.*/,"",$2); print $2; exit}')
[ -z "$_wan_ip" ] && _wan_ip=$(ip -4 addr show dev pppoe-wan 2>/dev/null | \
    awk '/inet /{gsub(/\/.*/,"",$2); print $2; exit}')
_wan6_ip=$(ip -6 addr show dev wan 2>/dev/null | \
    grep -v "fe80" | awk '/inet6 /{gsub(/\/.*/,"",$2); print $2; exit}')
_gw=$(ip route show default 2>/dev/null | awk '{print $3; exit}')

if [ -n "$_wan_ip" ]; then
    _ok "WAN IPv4: $_wan_ip（网关: ${_gw:-未知}）"
else
    _err "WAN IPv4: 未获取到地址"
fi
[ -n "$_wan6_ip" ] && _info "WAN IPv6: $_wan6_ip" || _info "WAN IPv6: 未启用"

_lan_ip=$(ip -4 addr show dev br-lan 2>/dev/null | \
    awk '/inet /{gsub(/\/.*/,"",$2); print $2; exit}')
[ -n "$_lan_ip" ] && _info "LAN IP  : $_lan_ip"

if ping -c1 -W2 223.5.5.5 >/dev/null 2>&1; then
    _ok "互联网: 已连接"
else
    _warn "互联网: 无法访问"
fi

# SSH 空密码警告
if grep -q "^root::" /etc/shadow 2>/dev/null || \
   grep -q "^root:[!*]*:" /etc/shadow 2>/dev/null; then
    _err "SSH root 密码为空！请执行: passwd root"
fi

# ── Wi-Fi 状态 ────────────────────────────────
_title "【Wi-Fi】"
_wifi_found=0
for _phy in /sys/class/ieee80211/phy*; do
    [ -d "$_phy" ] || continue
    _wifi_found=1
    _phyname="${_phy##*/}"
    _band=$(iw phy "$_phyname" info 2>/dev/null | \
        awk '/MHz/{if($1>5000){b="5GHz";exit} else b="2.4GHz"} END{print b}')
    [ -z "$_band" ] && _band="未知"
    _iface=$(iw dev 2>/dev/null | awk -v p="$_phyname" \
        '$0~"phy#"substr(p,4){found=1} found && /Interface/{print $2; exit}')
    if [ -n "$_iface" ]; then
        _ssid=$(iwinfo "$_iface" info 2>/dev/null | awk -F'"' '/ESSID/{print $2}')
        _chan=$(iwinfo "$_iface" info 2>/dev/null | awk '/Channel/{print $4}')
        _cli=$(iw dev "$_iface" station dump 2>/dev/null | grep -c "^Station")
        _ok "${_band} (${_iface}): SSID=${_ssid:-未知} 频道=${_chan:-?} 客户端=${_cli:-0}"
    else
        _warn "${_band} (${_phyname}): 未启用"
    fi
done
[ "$_wifi_found" -eq 0 ] && _warn "未检测到无线网卡"

# ── 系统资源 ──────────────────────────────────
_title "【系统资源】"
# Flash
_fp=$(df /overlay 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5); print $5}')
_fu=$(df -h /overlay 2>/dev/null | awk 'NR==2{print $3}')
_ft=$(df -h /overlay 2>/dev/null | awk 'NR==2{print $2}')
if [ -n "$_fp" ]; then
    [ "$_fp" -ge 90 ] && _err "Flash: ${_fu}/${_ft} (${_fp}%) — 空间严重不足" || \
    { [ "$_fp" -ge 75 ] && _warn "Flash: ${_fu}/${_ft} (${_fp}%)" || \
      _ok "Flash: ${_fu}/${_ft} (${_fp}%)"; }
fi

# 内存
_mu=$(free -m 2>/dev/null | awk '/Mem:/{print $3}')
_mt=$(free -m 2>/dev/null | awk '/Mem:/{print $2}')
_mp2=0; [ "${_mt:-0}" -gt 0 ] && _mp2=$(( _mu * 100 / _mt ))
[ "$_mp2" -ge 85 ] && \
    _warn "内存: ${_mu}MB/${_mt}MB (${_mp2}%)" || \
    _ok   "内存: ${_mu}MB/${_mt}MB (${_mp2}%)"

# Swap
_st=$(awk '/SwapTotal/{print $2}' /proc/meminfo 2>/dev/null)
_sf=$(awk '/SwapFree/{print $2}'  /proc/meminfo 2>/dev/null)
if [ "${_st:-0}" -gt 0 ]; then
    _su=$(( (_st - _sf) / 1024 )); _stm=$(( _st / 1024 ))
    _ok "Swap: ${_su}MB/${_stm}MB"
else
    _warn "Swap: 未激活"
    _hint "建议将 U 盘格式化为 ext4 以支持 swap"
fi

# 负载
_load=$(awk '{print $1" "$2" "$3}' /proc/loadavg 2>/dev/null)
_ncpu=$(grep -c "^processor" /proc/cpuinfo 2>/dev/null || echo 1)
_l1=$(echo "$_load" | awk '{print $1}' | cut -d. -f1)
[ "${_l1:-0}" -gt "$_ncpu" ] && \
    _warn "负载: $_load（超过 CPU 数 ${_ncpu}）" || \
    _ok   "负载: $_load（${_ncpu} 核）"

# 运行时间
_ups=$(awk '{printf "%d",$1}' /proc/uptime 2>/dev/null)
[ -n "$_ups" ] && \
    _info "运行: $((_ups/3600))时$((_ups%3600/60))分"

# CPU 温度
_temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
if [ -n "$_temp" ]; then
    _tc=$((_temp / 1000))
    if [ "$_temp" -gt 75000 ]; then
        _err "CPU温度: ${_tc}°C（过高！）"
        _hint "执行 360v6-tune --mode=powersave 降温"
    elif [ "$_temp" -gt 65000 ]; then
        _warn "CPU温度: ${_tc}°C（偏高）"
    else
        _ok "CPU温度: ${_tc}°C"
    fi
fi

# ── USB & 应用 ────────────────────────────────
_title "【USB & 应用】"
if [ -n "$_USB" ]; then
    _udev=$(awk -v mp="$_USB " '$0~mp{print $1; exit}' /proc/mounts 2>/dev/null)
    _ufs=$(awk -v mp="$_USB " '$0~mp{print $3; exit}' /proc/mounts 2>/dev/null)
    _ufree=$(df -h "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
    _uused=$(df -h "$_USB" 2>/dev/null | awk 'NR==2{print $3}')
    _utotal=$(df -h "$_USB" 2>/dev/null | awk 'NR==2{print $2}')
    _ok "USB: $_USB (${_udev:-?}) 文件系统: ${_ufs:-?}"
    _info "容量: 已用 ${_uused:-?} / ${_utotal:-?}，剩余 ${_ufree:-?}"
    case "${_ufs:-}" in
        vfat|exfat|fat*)
            _warn "文件系统 ${_ufs} 不支持 swap 和权限，建议格式化为 ext4" ;;
    esac
else
    _err "USB: 未检测到已挂载的 U 盘"
fi

# Docker
echo ""
printf "${_BOLD}[ Docker ]${_N}\n"
if [ -n "$_USB" ] && [ -f "$_USB/docker-bin/dockerd" ]; then
    _dver=$(cat "$_USB/docker-bin/version.txt" 2>/dev/null || echo "未知")
    if docker info >/dev/null 2>&1; then
        _crun=$(docker ps -q 2>/dev/null | wc -l | tr -d ' ')
        _call=$(docker ps -aq 2>/dev/null | wc -l | tr -d ' ')
        _driver=$(docker info 2>/dev/null | awk '/Storage Driver/{print $3}')
        _ok "Docker ${_dver}: 运行中（容器 ${_crun}/${_call}）"
        [ "${_driver:-}" = "vfs" ] && \
            _warn "存储驱动: vfs（性能较差，缺少 overlay 内核模块）" || \
            _info "存储驱动: ${_driver:-未知}"
    else
        _warn "Docker ${_dver}: 已安装但未运行"
        _hint "执行 360v6-health --fix 或 /etc/init.d/dockerd start"
    fi
else
    _warn "Docker: 未安装"
fi

# AGH
echo ""
printf "${_BOLD}[ AdGuardHome ]${_N}\n"
if [ -n "$_USB" ] && [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
    _aver=$(cat "$_USB/adguardhome-bin/version.txt" 2>/dev/null || \
        "$_USB/adguardhome-bin/AdGuardHome" --version 2>/dev/null | \
        grep -o 'v[0-9.]*' | head -1 || echo "未知")

    _web_port=3000
    [ -f "$_USB/AdGuardHome/AdGuardHome.yaml" ] && {
        _wp=$(grep -m1 "^ *port:" "$_USB/AdGuardHome/AdGuardHome.yaml" 2>/dev/null | \
            awk '{print $2}')
        [ -n "$_wp" ] && _web_port="$_wp"
    }

    if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
        _ok "AGH ${_aver}: 运行中（DNS:53 Web:${_web_port}）"

        [ ! -f "$_USB/.agh-finalized" ] && {
            _warn "AGH 尚未完成初始化向导"
            _hint "1. 访问 http://192.168.2.1:${_web_port} 完成向导"
            _hint "2. 执行 AGH_USER=xxx AGH_PASS=xxx agh-finalize"
        }

        # DNS 统计（需已 finalize）
        if command -v curl >/dev/null 2>&1 && [ -f "$_USB/.agh-finalized" ]; then
            _au=$(cat "$_USB/.agh-user" 2>/dev/null)
            _ap=$(cat "$_USB/.agh-pass" 2>/dev/null)
            _stats=$(curl -s --max-time 3 \
                ${_au:+--user "${_au}:${_ap}"} \
                "http://127.0.0.1:${_web_port}/control/stats" 2>/dev/null)
            if echo "$_stats" | grep -q '"num_dns_queries"'; then
                _total=$(echo "$_stats" | grep -o '"num_dns_queries":[0-9]*' | cut -d: -f2)
                _blocked=$(echo "$_stats" | grep -o '"num_blocked_filtering":[0-9]*' | cut -d: -f2)
                _bpct=0
                [ "${_total:-0}" -gt 0 ] && _bpct=$(( _blocked * 100 / _total ))
                _info "DNS统计: 查询 ${_total:-0} / 拦截 ${_blocked:-0} (${_bpct}%)"
            fi
            # 上游 DNS 显示
            [ -f "$_USB/AdGuardHome/AdGuardHome.yaml" ] && {
                _up=$(grep -A5 "^upstream_dns:" "$_USB/AdGuardHome/AdGuardHome.yaml" \
                    2>/dev/null | grep "^ *-" | head -3 | sed 's/^ *- //' | tr '\n' ' ')
                [ -n "$_up" ] && _info "上游DNS: ${_up}"
            }
        fi
        _info "管理界面: http://192.168.2.1:${_web_port}"
    else
        _err "AGH ${_aver}: 未运行"
        _hint "执行 360v6-health --fix 或 /etc/init.d/adguardhome start"
    fi
else
    _warn "AGH: 未安装"
fi

# ── 快捷命令 ──────────────────────────────────
_title "【命令参考】"
echo "  360v6-status                    查看本状态报告"
echo "  360v6-health [--fix]            健康检查 / 自动修复"
echo "  360v6-tune --mode=...           性能调节 (performance|balanced|powersave)"
echo "  360v6-upgrade --docker|--agh    升级组件"
echo "  agh-finalize                    AGH 向导完成后执行（接管 DNS）"
echo "  360v6-uninstall [--yes]         卸载所有组件"
echo ""
STATUSEOF
chmod +x /usr/bin/360v6-status

# ============================================================
# 360v6-health（V5.0 = V4.0 + 双路 DNS 冲突检测）
# ============================================================
cat > /usr/bin/360v6-health << 'HEALTHEOF'
#!/bin/sh
_SD="/etc/install-state"
_fix=0
[ "$1" = "--fix" ] && _fix=1

_ok()  { echo "[OK]  $1"; }
_warn(){ echo "[..]  $1"; }
_err() { echo "[!!]  $1"; }

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

_fix_action() {
    if [ "$_fix" -eq 1 ]; then
        echo "  → 执行修复: $1"
        eval "$2"
    else
        echo "  → 修复建议: $1（加 --fix 自动执行）"
    fi
}

echo "=== 360 V6 健康检查 V5.0 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo ""
_errs=0
_USB=$(_get_usb_mount)

# CPU 温度
_temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
if [ -n "$_temp" ]; then
    _tc=$((_temp / 1000))
    if [ "$_temp" -gt 75000 ]; then
        _err "CPU 过热 (${_tc}°C)"
        _fix_action "切换 CPU powersave" \
            "for g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
                [ -f \"\$g\" ] && echo powersave > \"\$g\" 2>/dev/null; done"
        _errs=$((_errs+1))
    else
        _ok "CPU 温度: ${_tc}°C"
    fi
fi

# Flash
_fp=$(df /overlay 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5);print $5}')
if [ -z "$_fp" ]; then
    _warn "无法读取 Flash"
elif [ "$_fp" -ge 90 ]; then
    _err "Flash ${_fp}%（严重不足）"
    _fix_action "清理临时缓存" \
        "rm -rf /tmp/opkg-lists /var/cache/apk 2>/dev/null"
    _errs=$((_errs+1))
elif [ "$_fp" -ge 75 ]; then
    _warn "Flash ${_fp}%（偏高）"
else
    _ok "Flash ${_fp}%"
fi

# Swap
grep -q swapfile /proc/swaps 2>/dev/null && \
    _ok "Swap 已激活" || \
    _warn "Swap 未激活（重启后会自动恢复）"

# Docker
if [ -n "$_USB" ] && [ -f "$_USB/docker-bin/dockerd" ]; then
    if docker info >/dev/null 2>&1; then
        _ok "Docker 运行中"
    else
        _err "Docker 未运行"
        _fix_action "启动 dockerd" "/etc/init.d/dockerd start"
        _errs=$((_errs+1))
    fi
fi

# AGH + DNS 冲突检测（ss 和 netstat 双路兼容）
if [ -n "$_USB" ] && [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
    if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
        _ok "AdGuardHome 运行中"
        # DNS 冲突检测
        _dns53=""
        if command -v ss >/dev/null 2>&1; then
            _dns53=$(ss -lnup 2>/dev/null | awk '$5~/:53$/ && /dnsmasq/{print 1; exit}')
        fi
        [ -z "$_dns53" ] && command -v netstat >/dev/null 2>&1 && \
            _dns53=$(netstat -lnup 2>/dev/null | awk '$4~/:53$/ && $NF~/dnsmasq/{print 1; exit}')
        if [ "${_dns53}" = "1" ]; then
            _err "DNS 冲突：dnsmasq 仍监听端口 53"
            _fix_action "禁用 dnsmasq DNS 端口" \
                "uci set dhcp.@dnsmasq[0].port='0';
                 uci commit dhcp;
                 /etc/init.d/dnsmasq reload"
            _errs=$((_errs+1))
        else
            _ok "DNS 无冲突（dnsmasq 未占用 53）"
        fi
    else
        _err "AdGuardHome 未运行"
        _fix_action "启动 AGH" "/etc/init.d/adguardhome start"
        _errs=$((_errs+1))
    fi
fi

# SSH 空密码
grep -q "^root::" /etc/shadow 2>/dev/null && {
    _err "SSH root 密码为空（安全风险）"
    echo "  → 修复: 执行 passwd root 设置密码"
    _errs=$((_errs+1))
}

# WAN 连通性
ping -c1 -W3 223.5.5.5 >/dev/null 2>&1 && \
    _ok "WAN 网络连通" || { _err "WAN 无法访问外网"; _errs=$((_errs+1)); }

echo ""
if [ "$_errs" -eq 0 ]; then
    echo "[完成] 健康检查通过，无异常"
else
    _suffix="（加 --fix 自动修复）"
    [ "$_fix" -eq 1 ] && _suffix="（已尝试自动修复）"
    echo "[完成] 发现 ${_errs} 个问题${_suffix}"
fi
HEALTHEOF
chmod +x /usr/bin/360v6-health

# ============================================================
# 360v6-tune（V5.0 = V4.0，加 IO 调度器优化）
# ============================================================
cat > /usr/bin/360v6-tune << 'TUNEOF'
#!/bin/sh
_MODE="${1#--mode=}"
if [ -z "$_MODE" ]; then
    echo "用法: 360v6-tune --mode=performance|balanced|powersave"
    echo "当前: $(cat /etc/install-state/perf-mode 2>/dev/null || echo '未设置')"
    exit 1
fi

_log() { echo "[OK] $1"; }
_set_gov() {
