#!/bin/sh
_MODE="${1#--mode=}"
[ -z "$_MODE" ] && {
    echo "用法: 360v6-tune --mode=performance|balanced|powersave"
    exit 1
}

_tcp_cong_available() {
    grep -q "$1" /proc/sys/net/ipv4/tcp_available_congestion_control 2>/dev/null
}
_log() { echo "[OK] $1"; }

# FIX: 用 for 循环逐个写 governor，避免 glob 展开失败时写入字面量路径
_set_governor() {
    for _gov_f in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        [ -f "$_gov_f" ] && echo "$1" > "$_gov_f" 2>/dev/null
    done
}

case "$_MODE" in
performance)
    _log "性能模式"
    _set_governor performance
    _tcp_cong_available bbr   && echo bbr   > /proc/sys/net/ipv4/tcp_congestion_control
    echo 65536 > /proc/sys/net/nf_conntrack_max 2>/dev/null
    ;;
balanced)
    _log "平衡模式"
    _set_governor ondemand
    _tcp_cong_available cubic && echo cubic > /proc/sys/net/ipv4/tcp_congestion_control
    echo 32768 > /proc/sys/net/nf_conntrack_max 2>/dev/null
    ;;
powersave)
    _log "省电模式"
    _set_governor powersave
    _tcp_cong_available cubic && echo cubic > /proc/sys/net/ipv4/tcp_congestion_control
    echo 16384 > /proc/sys/net/nf_conntrack_max 2>/dev/null
    ;;
*)
    echo "未知模式: $_MODE"; exit 1
    ;;
esac

# I/O 调度优化（同样用 for 循环，避免 glob 问题）
for _dev in /sys/block/sd*/queue/scheduler /sys/block/mmcblk*/queue/scheduler; do
    [ -f "$_dev" ] && grep -q "mq-deadline" "$_dev" 2>/dev/null && \
        echo mq-deadline > "$_dev" 2>/dev/null
done

mkdir -p /etc/install-state
echo "$_MODE" > /etc/install-state/perf-mode
TUNEOF
