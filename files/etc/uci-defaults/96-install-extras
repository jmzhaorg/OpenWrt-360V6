cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
_LT="usb-extras"
_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-usb.lock"
_SD="/etc/install-state"
_MF="/etc/install-usb-mount"

# Docker 版本按优先级排列；下载失败时自动尝试下一个
_DOCKER_VERS="28.1.0 27.5.1 26.1.4"
_DOCKER_BASE="https://download.docker.com/linux/static/stable/aarch64"
_AGH_URL="https://static.adguard.com/adguardhome/release/AdGuardHome_linux_arm64.tar.gz"

# 留空则跳过 checksum 验证；STRICT_CHECKSUM=1 时不匹配直接拒绝
_DOCKER_EXPECTED_SHA256="${DOCKER_SHA256:-}"
_AGH_EXPECTED_SHA256="${AGH_SHA256:-}"
_STRICT_CHECKSUM="${STRICT_CHECKSUM:-0}"

log() {
    __lm="[$(date '+%H:%M:%S')] $1"
    echo "$__lm"
    echo "$__lm" | logger -t "$_LT"
}

_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { echo "$_mp"; return 0; }
    done
    return 1
}

_is_usb_dev() {
    case "$1" in
        /dev/sd[a-z][0-9]*|/dev/mmcblk[0-9]*p[0-9]*) return 0 ;;
        *) return 1 ;;
    esac
}

_timeout() {
    __tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$__tt" "$@" 2>/dev/null
        return $?
    fi
    "$@" &
    __pid=$!
    __cnt=0
    while [ "$__cnt" -lt "$__tt" ]; do
        kill -0 "$__pid" 2>/dev/null || { wait "$__pid"; return $?; }
        sleep 1
        __cnt=$((__cnt + 1))
    done
    kill -9 "$__pid" 2>/dev/null
    wait "$__pid" 2>/dev/null
    return 124
}

# FIX: _tar_extract 原子性增强——全部 mv 成功才清理 tmp
_tar_extract() {
    __tgz="$1"; __dst="$2"; __subdir="$3"
    __tmp="${__dst}.xtmp$$"
    rm -rf "$__tmp"
    mkdir -p "$__tmp" "$__dst" || return 1
    tar xzf "$__tgz" -C "$__tmp" 2>/dev/null || { rm -rf "$__tmp"; return 1; }

    if [ -n "$__subdir" ] && [ -d "$__tmp/$__subdir" ]; then
        __src="$__tmp/$__subdir"
    else
        __src="$__tmp"
    fi

    __moved=0
    for __f in "$__src/"*; do
        [ -e "$__f" ] || continue
        __bn="${__f##*/}"
        rm -rf "$__dst/$__bn"
        mv "$__f" "$__dst/" 2>/dev/null || { rm -rf "$__tmp"; return 1; }
        __moved=$((__moved + 1))
    done
    rm -rf "$__tmp"
    [ "$__moved" -gt 0 ]
}

# FIX: 最小文件尺寸调整为更合理的值（Docker ~70MB，AGH ~15MB）
_wget_retry() {
    __url="$1"; __out="$2"; __min_size="${3:-0}"
    __r=0
    while [ "$__r" -lt 3 ]; do
        wget -q --timeout=120 --tries=1 -O "$__out" "$__url" 2>/dev/null
        if [ -f "$__out" ]; then
            __sz=$(wc -c < "$__out" 2>/dev/null || echo 0)
            if [ "${__sz:-0}" -ge "$__min_size" ] && [ "${__sz:-0}" -gt 0 ]; then
                return 0
            fi
        fi
        rm -f "$__out"
        __r=$((__r + 1))
        [ "$__r" -lt 3 ] && { log "下载失败 (${__r}/3)，重试..."; sleep 3; }
    done
    return 1
}

_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" 2>/dev/null | cut -d' ' -f1
    elif command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha256 "$1" 2>/dev/null | cut -d' ' -f2
    else
        echo ""
    fi
}

_verify_checksum() {
    __file="$1"; __expected="$2"; __name="$3"
    [ -z "$__expected" ] && {
        log "警告: $__name 未配置 SHA256，跳过校验（建议设置 DOCKER_SHA256/AGH_SHA256）"
        return 0
    }
    __actual=$(_sha256 "$__file")
    [ -z "$__actual" ] && { log "警告: 无法计算 $__name 的 SHA256"; return 0; }
    if [ "$__actual" = "$__expected" ]; then
        log "$__name 校验通过"
        return 0
    fi
    log "错误: $__name 校验和不匹配（期望: $__expected，实际: $__actual）"
    [ "$_STRICT_CHECKSUM" = "1" ] && return 1
    return 0
}

_pkg_install() {
    if command -v apk >/dev/null 2>&1; then
        apk add --no-cache "$@" >/dev/null 2>&1
    elif command -v opkg >/dev/null 2>&1; then
        opkg install "$@" >/dev/null 2>&1
    else
        return 1
    fi
}

mkdir -p "$_SD"

# ── 参数解析 ──────────────────────────────────
__self_heal=0; __force=0; __mp_arg=""
for _a in "$@"; do
    case "$_a" in
        --self-heal) __self_heal=1 ;;
        --force)     __force=1 ;;
        *)           [ -z "$__mp_arg" ] && __mp_arg="$_a" ;;
    esac
done

# ── 自愈模式 ─────────────────────────────────
if [ "$__self_heal" -eq 1 ]; then
    [ -f /etc/install-extras-done ] || exit 0
    [ -f "$_DONE" ] && exit 0
    __last_heal=$(cat "$_SD/last-self-heal" 2>/dev/null || echo 0)
    __now=$(awk '{printf "%d", $1}' /proc/uptime 2>/dev/null || echo 0)
    __elapsed=$((__now - __last_heal))
    if [ "$__elapsed" -lt 300 ] && [ "$__elapsed" -gt 0 ]; then
        log "自愈冷却中（${__elapsed}s < 300s）"
        exit 0
    fi
    _USB=$(_get_usb_mount)
    [ -n "$_USB" ] && {
        echo "$__now" > "$_SD/last-self-heal"
        exec /usr/lib/install-extras/install-usb.sh "$_USB"
    }
    exit 0
fi

# ── --force 清零 ─────────────────────────────
if [ "$__force" -eq 1 ]; then
    rm -f "$_DONE" "$_SD/docker-done" "$_SD/agh-done"
    rm -f "$_SD/docker-failures" "$_SD/agh-failures"
    rm -f /etc/adguardhome.yaml /etc/adguardhome/adguardhome.yaml
    log "--force：已清零所有状态"
fi

[ -f "$_DONE" ] && exit 0

# ── 单例锁（FIX: 用 ln -s 增强原子性）────────
if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && exit 0
    rm -f "$_LOCK"
fi
if ! ln -s $$ "$_LOCK" 2>/dev/null; then
    # 退路：ln 不支持时回退到普通写
    echo $$ > "$_LOCK"
fi

# ── DNS 快照（仅用于退出时恢复，不覆盖 AGH 接管后的配置）
__dns_backup=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_backup" ] && __dns_backup="nameserver 127.0.0.1"

_cleanup() {
    rm -f "$_LOCK"
    # 只在 AGH 未接管时才恢复旧 DNS
    if [ ! -f "$_SD/agh-done" ]; then
        printf '%s\n' "$__dns_backup" > /etc/resolv.conf 2>/dev/null
    fi
    sync 2>/dev/null || true
}
trap '_cleanup' EXIT INT TERM

# ── 确定 USB 挂载点 ───────────────────────────
_USB=""
[ -n "$__mp_arg" ] && _is_mounted "$__mp_arg" && _USB="$__mp_arg"
[ -z "$_USB" ] && _USB=$(_get_usb_mount)
[ -z "$_USB" ] && { log "未找到已挂载的 U 盘"; exit 1; }

__dev=$(awk -v mp="$_USB " '$0 ~ mp {print $1; exit}' /proc/mounts 2>/dev/null)
_is_usb_dev "$__dev" || { log "设备 ${__dev:-未知} 不是 USB 分区，跳过"; exit 0; }

echo "$_USB" > "$_MF"
log "部署开始 | U 盘: $_USB ($__dev)"

# ── 检查 U 盘可用空间（至少 1GB）────────────
__usb_free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
[ "${__usb_free:-0}" -lt 1048576 ] && { log "U 盘可用空间不足（< 1GB）"; exit 1; }

# ── 临时 DNS ─────────────────────────────────
_upstream_dns=$(uci get dhcp.@dnsmasq[0].server 2>/dev/null | head -1 | cut -d'/' -f3)
if [ -n "$_upstream_dns" ]; then
    echo "nameserver $_upstream_dns" > /etc/resolv.conf
else
    printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
fi
log "临时 DNS 已注入"

# ── Swap ──────────────────────────────────────
_swap_mb=256
_ram_mb=$(free -m 2>/dev/null | awk '/Mem:/{print $2}')
[ "${_ram_mb:-0}" -lt 256 ] && _swap_mb=512
__swapfile="$_USB/swapfile"

if ! grep -q "$__swapfile" /proc/swaps 2>/dev/null; then
    if [ ! -f "$__swapfile" ]; then
        log "创建 ${_swap_mb}MB swap..."
        if dd if=/dev/zero of="${__swapfile}.tmp" bs=1M count=$_swap_mb 2>/dev/null; then
            mv "${__swapfile}.tmp" "$__swapfile" && \
            chmod 600 "$__swapfile" && \
            mkswap "$__swapfile" >/dev/null 2>&1 || {
                rm -f "$__swapfile"
                log "swap 格式化失败"
            }
        else
            rm -f "${__swapfile}.tmp"
            log "swap 创建失败（空间不足？）"
        fi
    fi
    if [ -f "$__swapfile" ]; then
        swapon "$__swapfile" 2>/dev/null
        # FIX: 验证 swap 真正激活
        if grep -q "$__swapfile" /proc/swaps 2>/dev/null; then
            log "swap 已激活 (${_swap_mb}MB)"
            echo 10   > /proc/sys/vm/swappiness 2>/dev/null
            echo 8192 > /proc/sys/vm/min_free_kbytes 2>/dev/null
        else
            log "swap swapon 失败（文件系统不支持？）"
        fi
    fi
fi

__dl_dir="$_USB/.downloads"
mkdir -p "$__dl_dir"

# ── 并发预下载（FIX: 每个版本都检查，只下载真正缺失的）──
_prefetch_downloads() {
    __pids=""

    # Docker：找第一个未缓存的版本启动后台下载
    for _dv in $_DOCKER_VERS; do
        __dtgz="$__dl_dir/docker-${_dv}.tgz"
        if [ ! -f "$__dtgz" ]; then
            log "预下载 Docker ${_dv}（后台）..."
            (
                _wget_retry "$_DOCKER_BASE/docker-${_dv}.tgz" \
                    "${__dtgz}.tmp" 62914560 && \
                mv "${__dtgz}.tmp" "$__dtgz" || rm -f "${__dtgz}.tmp"
            ) &
            __pids="$__pids $!"
            break   # 只预取优先级最高的一个
        fi
    done

    # AGH：未缓存时后台下载
    __atgz="$__dl_dir/AdGuardHome_linux_arm64.tar.gz"
    if [ ! -f "$__atgz" ]; then
        log "预下载 AdGuardHome（后台）..."
        (
            _wget_retry "$_AGH_URL" "${__atgz}.tmp" 15728640 && \
            mv "${__atgz}.tmp" "$__atgz" || rm -f "${__atgz}.tmp"
        ) &
        __pids="$__pids $!"
    fi

    # 等待所有预下载完成
    for __pid in $__pids; do
        wait "$__pid" 2>/dev/null
    done
}

# ══ Docker 部署 ═══════════════════════════════════════════════
_DOCKER_FAIL=0
log "--- Docker 部署 ---"
__docker_fail_count=$(cat "$_SD/docker-failures" 2>/dev/null || echo 0)

if [ -f "$_SD/docker-done" ]; then
    log "Docker 已完成，跳过"
elif [ "${__docker_fail_count:-0}" -ge 3 ]; then
    log "Docker 连续失败 ${__docker_fail_count} 次，跳过（可用 --force 重置）"
    _DOCKER_FAIL=1
else
    __dbin="$_USB/docker-bin"
    __ddata="$_USB/docker-data"
    mkdir -p "$__dbin" "$__ddata" /etc/docker

    # 预下载
    _prefetch_downloads

    __docker_ver=""
    for _dv in $_DOCKER_VERS; do
        __dtgz="$__dl_dir/docker-${_dv}.tgz"

        # 缓存不存在则现场下载
        if [ ! -f "$__dtgz" ]; then
            log "下载 Docker ${_dv}..."
            # FIX: 最小尺寸调整为 60MB（实际包约 70MB）
            _wget_retry "$_DOCKER_BASE/docker-${_dv}.tgz" \
                "${__dtgz}.tmp" 62914560 || continue
            _verify_checksum "${__dtgz}.tmp" \
                "$_DOCKER_EXPECTED_SHA256" "Docker ${_dv}" || {
                rm -f "${__dtgz}.tmp"; continue
            }
            gzip -t "${__dtgz}.tmp" 2>/dev/null || {
                log "Docker ${_dv} 包完整性校验失败"
                rm -f "${__dtgz}.tmp"; continue
            }
            mv "${__dtgz}.tmp" "$__dtgz"
        fi

        log "解压 Docker ${_dv}..."
        rm -rf "$__dbin"/* 2>/dev/null
        if _tar_extract "$__dtgz" "$__dbin" "docker" && [ -f "$__dbin/dockerd" ]; then
            __docker_ver="$_dv"
            break
        else
            log "Docker ${_dv} 解压失败，删除缓存并尝试下一版本"
            rm -f "$__dtgz"
        fi
    done

    if [ -n "$__docker_ver" ]; then
        for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc; do
            [ -f "$__dbin/$_b" ] && ln -sf "$__dbin/$_b" "/usr/bin/$_b" 2>/dev/null
        done

        # overlay2 检测
        __storage_driver="overlay2"
        if ! grep -q "^overlay$" /proc/filesystems 2>/dev/null; then
            log "overlay 模块不可用，降级为 vfs"
            __storage_driver="vfs"
        fi

        # FIX: fixed-cidr 修正为正确的网络地址 172.17.0.0/16
        cat > /etc/docker/daemon.json << DOCKEREOF
{
  "data-root": "$__ddata",
  "storage-driver": "$__storage_driver",
  "iptables": true,
  "bridge": "docker0",
  "fixed-cidr": "172.17.0.0/16",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"},
  "registry-mirrors": ["https://docker.m.daocloud.io"]
}
DOCKEREOF
        log "daemon.json 已写入"

        cat > /etc/init.d/dockerd << 'DINITEOF'
#!/bin/sh /etc/rc.common
START=99; STOP=10; USE_PROCD=1

start_service() {
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$_mp" ] && [ -f "$_mp/docker-bin/dockerd" ] || return 1

    # FIX: 只在未挂载时才挂载 cgroup2，避免重复挂载警告
    if ! grep -q "^[^ ]* /sys/fs/cgroup cgroup2" /proc/mounts 2>/dev/null; then
        mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
    fi

    procd_open_instance
    procd_set_param command "$_mp/docker-bin/dockerd" \
        --config-file /etc/docker/daemon.json
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 3
    procd_close_instance
}

stop_service() { pkill dockerd 2>/dev/null || true; }
DINITEOF
        chmod +x /etc/init.d/dockerd
        /etc/init.d/dockerd enable 2>/dev/null
        /etc/init.d/dockerd start 2>/dev/null
        sleep 5

        if _timeout 10 docker info >/dev/null 2>&1; then
            log "Docker $__docker_ver 已启动并响应"
        else
            log "Docker $__docker_ver 已启动（守护进程仍在初始化中）"
        fi

        date '+%Y-%m-%d %H:%M:%S' > "$_SD/docker-done"
        rm -f "$_SD/docker-failures"
    else
        _DOCKER_FAIL=1
        echo $((__docker_fail_count + 1)) > "$_SD/docker-failures"
        log "Docker 部署失败（已尝试全部版本）"
    fi
fi

# ══ AdGuardHome 部署 ═══════════════════════════════════════════
_AGH_FAIL=0
log "--- AdGuardHome 部署 ---"
__agh_fail_count=$(cat "$_SD/agh-failures" 2>/dev/null || echo 0)

if [ -f "$_SD/agh-done" ]; then
    log "AGH 已完成，跳过"
elif [ "${__agh_fail_count:-0}" -ge 3 ]; then
    log "AGH 连续失败 ${__agh_fail_count} 次，跳过（可用 --force 重置）"
    _AGH_FAIL=1
else
    __abin="$_USB/adguardhome-bin"
    __adata="$_USB/AdGuardHome"
    mkdir -p "$__abin" "$__adata"

    __atgz="$__dl_dir/AdGuardHome_linux_arm64.tar.gz"

    if [ ! -f "$__abin/AdGuardHome" ]; then
        # 若预下载未完成则现场下载
        if [ ! -f "$__atgz" ]; then
            log "下载 AdGuardHome..."
            # FIX: 最小尺寸 15MB
            if ! _wget_retry "$_AGH_URL" "${__atgz}.tmp" 15728640; then
                _AGH_FAIL=1
            else
                if ! _verify_checksum "${__atgz}.tmp" \
                        "$_AGH_EXPECTED_SHA256" "AdGuardHome"; then
                    rm -f "${__atgz}.tmp"
                    _AGH_FAIL=1
                else
                    mv "${__atgz}.tmp" "$__atgz"
                fi
            fi
        fi

        if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__atgz" ]; then
            log "解压 AdGuardHome..."
            # AGH tar 包结构: AdGuardHome/AdGuardHome (二进制在子目录内)
            if _tar_extract "$__atgz" "$__abin" "AdGuardHome" && \
               [ -f "$__abin/AdGuardHome" ]; then
                chmod +x "$__abin/AdGuardHome"
                log "AGH 二进制就绪"
            else
                log "AGH 解压失败"
                rm -f "$__atgz"
                _AGH_FAIL=1
            fi
        fi
    fi

    if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__abin/AdGuardHome" ]; then
        ln -sf "$__abin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null

        # luci 插件为可选，失败不影响主流程
        if _pkg_install luci-app-adguardhome 2>/dev/null; then
            log "LuCI AGH 插件已安装"
        else
            log "LuCI AGH 插件安装失败（可选，不影响功能）"
        fi

        # UCI 配置：仅当 schema 存在时才设置
        if uci get adguardhome.config >/dev/null 2>&1; then
            uci set adguardhome.config.work_dir="$__adata" 2>/dev/null
            uci set adguardhome.config.enabled='1' 2>/dev/null
            uci commit adguardhome 2>/dev/null
        fi

        /etc/init.d/adguardhome enable 2>/dev/null
        /etc/init.d/adguardhome restart 2>/dev/null

        __agh_up=0
        __wi=0
        while [ "$__wi" -lt 15 ]; do
            pgrep -f "AdGuardHome" >/dev/null 2>&1 && { __agh_up=1; break; }
            sleep 1
            __wi=$((__wi + 1))
        done

        if [ "$__agh_up" -eq 1 ]; then
            # OOM 保护
            for _proc in dockerd containerd AdGuardHome; do
                _pid=$(pgrep -f "$_proc" 2>/dev/null | head -1)
                [ -n "$_pid" ] && echo -500 > "/proc/$_pid/oom_score_adj" 2>/dev/null
            done

            log "AGH 已启动 + OOM 保护已设置"
            log ">>> 访问 http://192.168.2.1:3000 完成向导 <<<"
            log ">>> 完成后执行: AGH_USER=xxx AGH_PASS=xxx agh-finalize <<<"
            rm -f "$_SD/agh-failures"
        else
            log "AGH 进程未在 15s 内启动"
            _AGH_FAIL=1
        fi
    else
        _AGH_FAIL=1
    fi

    [ "$_AGH_FAIL" -eq 1 ] && \
        echo $((__agh_fail_count + 1)) > "$_SD/agh-failures"
fi

# ── LuCI 缓存刷新 ─────────────────────────────
rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd reload 2>/dev/null || true

# ── 写入总完成标记 ────────────────────────────
# FIX: _DONE 只要两个组件都不是"硬性失败"就写入
# （部分完成也应持久化，防止重启后重复执行已成功的部分）
if [ "$_DOCKER_FAIL" -eq 0 ] && [ "$_AGH_FAIL" -eq 0 ]; then
    date '+%Y-%m-%d %H:%M:%S' > "$_DONE"
    log "部署完成 [Docker:OK AGH:OK]"
    exit 0
elif [ "$_DOCKER_FAIL" -eq 0 ] || [ "$_AGH_FAIL" -eq 0 ]; then
    log "部分完成 [Docker:$([ $_DOCKER_FAIL -eq 0 ] && echo OK || echo FAIL) AGH:$([ $_AGH_FAIL -eq 0 ] && echo OK || echo FAIL)]"
    exit 2
else
    log "部署失败 [Docker:FAIL AGH:FAIL]"
    exit 1
fi
USBEOF
chmod +x /usr/lib/install-extras/install-usb.sh

# ══════════════════════════════════════════════════════════════
# agh-finalize
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/agh-finalize << 'FINALEOF'
#!/bin/sh

_user="${AGH_USER:-}"
_pass="${AGH_PASS:-}"

if [ -z "$_user" ]; then
    echo "用法: AGH_USER=<用户名> AGH_PASS=<密码> agh-finalize"
    echo "注意: 密码通过环境变量传入，不会出现在命令行参数中"
    exit 1
fi

if [ -z "$_pass" ]; then
    if [ -t 0 ]; then
        printf "密码: "
        stty -echo 2>/dev/null
        read -r _pass
        stty echo 2>/dev/null
        echo ""
    else
        echo "[ERR] 非终端环境，请通过 AGH_PASS=xxx 环境变量传入密码"
        exit 1
    fi
fi

[ -z "$_pass" ] && { echo "[ERR] 密码不能为空"; exit 1; }

command -v curl >/dev/null 2>&1 || { echo "[ERR] 需要 curl"; exit 1; }
pgrep -f "AdGuardHome" >/dev/null 2>&1 || { echo "[ERR] AGH 未运行"; exit 1; }

# 多端口探测（AGH 默认端口 3000；其余为自定义场景备用）
# FIX: curl 凭据通过 --user 传入，在进程列表中不可见
_agh_port=""
for _p in 3000 8080 5354; do
    _hc=$(curl -s -o /dev/null -w "%{http_code}" --max-time 3 \
        --user "${_user}:${_pass}" \
        "http://127.0.0.1:${_p}/control/status" 2>/dev/null)
    if [ "$_hc" = "200" ]; then
        _agh_port="$_p"
        break
    fi
done

if [ -z "$_agh_port" ]; then
    echo "[ERR] 所有端口均验证失败，请确认用户名/密码及 AGH 是否完成初始化向导"
    exit 1
fi

echo "[OK] 验证成功（端口 ${_agh_port}），接管 DNS..."

uci set dhcp.@dnsmasq[0].port='0' 2>/dev/null
uci commit dhcp 2>/dev/null
/etc/init.d/dnsmasq reload 2>/dev/null
/etc/init.d/adguardhome restart 2>/dev/null

date '+%Y-%m-%d %H:%M:%S' > /etc/install-state/agh-done
echo "[OK] 完成！AGH 已接管 DNS（dnsmasq 端口已置 0）"
FINALEOF
chmod +x /usr/bin/agh-finalize

# ══════════════════════════════════════════════════════════════
# Docker 防火墙规则
# ══════════════════════════════════════════════════════════════
cat > /etc/hotplug.d/iface/99-docker-net << 'DOCKERFWEOF'
#!/bin/sh
[ "${ACTION}" = "ifup" ]   || exit 0
[ "${INTERFACE}" = "lan" ] || exit 0
sleep 2
# 允许 docker0 与 lan 之间双向转发
iptables -C FORWARD -i docker0 -o br-lan -j ACCEPT 2>/dev/null || \
    iptables -I FORWARD -i docker0 -o br-lan -j ACCEPT 2>/dev/null
iptables -C FORWARD -i br-lan -o docker0 -j ACCEPT 2>/dev/null || \
    iptables -I FORWARD -i br-lan -o docker0 -j ACCEPT 2>/dev/null
DOCKERFWEOF
chmod +x /etc/hotplug.d/iface/99-docker-net

# ══════════════════════════════════════════════════════════════
# 模块 B：run.sh
# ══════════════════════════════════════════════════════════════
cat > /usr/lib/install-extras/run.sh << 'RUNEOF'
#!/bin/sh
_LT="install-main"
_DONE="/etc/install-extras-done"
_LOCK="/tmp/install-main.lock"
_SD="/etc/install-state"

log() { echo "[$(date '+%H:%M:%S')] $1" | logger -t "$_LT"; }

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

mkdir -p "$_SD"
[ -f "$_DONE" ] && exit 0

# FIX: 同样使用 ln -s 增强锁原子性
if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && exit 0
    rm -f "$_LOCK"
fi
if ! ln -s $$ "$_LOCK" 2>/dev/null; then
    echo $$ > "$_LOCK"
fi

__fail=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
[ "${__fail:-0}" -ge 3 ] && { rm -f "$_LOCK"; exit 1; }

log "基础环境启动"
sleep 10

# 等待网络（最多 60s）
__ok=0
for _i in $(seq 1 12); do
    ping -c1 -W2 223.5.5.5 >/dev/null 2>&1 && { __ok=1; break; }
    sleep 5
done
if [ "$__ok" -eq 0 ]; then
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    rm -f "$_LOCK"
    log "网络超时，退出"
    exit 1
fi

# 安装基础包
if command -v apk >/dev/null 2>&1; then
    for __p in bash htop curl; do
        apk add --no-cache "$__p" >/dev/null 2>&1 && log "已安装: $__p"
    done
elif command -v opkg >/dev/null 2>&1; then
    opkg update >/dev/null 2>&1
    for __p in bash htop curl; do
        opkg install "$__p" >/dev/null 2>&1 && log "已安装: $__p"
    done
fi

date '+%Y-%m-%d %H:%M:%S' > "$_DONE"
rm -f "$_SD/phase1-failures" "$_LOCK"
log "基础环境完成"

# 触发 Phase 2（若 U 盘已在线）
if [ ! -f /etc/install-usb-done ]; then
    _mp=$(_get_usb_mount)
    [ -n "$_mp" ] && /usr/lib/install-extras/install-usb.sh "$_mp" &
fi
RUNEOF
chmod +x /usr/lib/install-extras/run.sh

# ══════════════════════════════════════════════════════════════
# Hotplug：iface（WAN 上线触发基础环境）
# ══════════════════════════════════════════════════════════════
cat > /etc/hotplug.d/iface/96-install-extras << 'IFACEEOF'
#!/bin/sh
[ "${ACTION:-}" = "ifup" ] || exit 0
case "${INTERFACE:-}" in wan|wan6|pppoe-wan) ;; *) exit 0 ;; esac
[ -f /etc/install-extras-done ] && exit 0
/usr/lib/install-extras/run.sh &
IFACEEOF
chmod +x /etc/hotplug.d/iface/96-install-extras

# ══════════════════════════════════════════════════════════════
# Hotplug：block（U 盘插拔）
# ══════════════════════════════════════════════════════════════
cat > /etc/hotplug.d/block/96-install-usb << 'BLOCKEOF'
#!/bin/sh
case "${DEVNAME:-}" in sd[a-z]*|mmcblk[0-9]*) ;; *) exit 0 ;; esac

# FIX: 移除事件处理完成后确保退出，逻辑更清晰
if [ "${ACTION:-}" = "remove" ]; then
    if [ -f /etc/install-usb-done ]; then
        logger -t "usb-extras" "U 盘移除，暂停依赖服务"
        /etc/init.d/dockerd stop 2>/dev/null
        /etc/init.d/adguardhome stop 2>/dev/null
    fi
    exit 0
fi

[ "${ACTION:-}" = "add" ] || exit 0
[ -f /etc/install-usb-done ]    && exit 0
[ -f /etc/install-extras-done ] || exit 0

# 等待系统挂载 U 盘（最多 24s）
_mp=""
for _i in $(seq 1 12); do
    for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_m " /proc/mounts 2>/dev/null && { _mp="$_m"; break 2; }
    done
    sleep 2
done

[ -n "$_mp" ] && /usr/lib/install-extras/install-usb.sh "$_mp" &
BLOCKEOF
chmod +x /etc/hotplug.d/block/96-install-usb

# 清理 uci-defaults 中的自身
rm -f /etc/uci-defaults/96-install-extras

log "V3.7 安装完成"
exit 0
